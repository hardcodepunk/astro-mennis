---
import "../styles/global.css"
import "@fontsource/bebas-neue/400.css"
import { ClientRouter } from "astro:transitions"
import Header from "../components/Header.astro"
import Footer from "../components/Footer.astro"
import { absoluteUrl, DEFAULT_DESCRIPTION, DEFAULT_SITE_URL, DEFAULT_TITLE, normalizeSiteUrl } from "../lib/seo"

const transparentHeaderPaths = ["/", "/about"]
const normalizedPath = Astro.url.pathname.replace(/\/$/, "") || "/"
const hasTransparentHeader = transparentHeaderPaths.includes(normalizedPath)
const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  canonical,
  canonicalPath,
  image,
  imageAlt,
  noindex = false,
  ogType = "website",
  twitterCard = "summary_large_image",
  twitterHandle,
  siteUrl = Astro.site?.toString() ?? DEFAULT_SITE_URL,
  jsonLd,
  preloadImage,
  preloadImageSrcset,
  preloadImageSizes,
} = Astro.props

const baseUrl = normalizeSiteUrl(siteUrl)
const canonicalUrl = absoluteUrl(canonical ?? canonicalPath ?? Astro.url.pathname, baseUrl)
const socialImageUrl = absoluteUrl(image, baseUrl)
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []

function escapeJsonLd(value: unknown) {
  return JSON.stringify(value).replaceAll("</script", "<\\/script")
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : null}
    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}

    <meta property="og:site_name" content="De Mennis" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl ? <meta property="og:url" content={canonicalUrl} /> : null}
    {socialImageUrl ? <meta property="og:image" content={socialImageUrl} /> : null}
    {socialImageUrl && imageAlt ? <meta property="og:image:alt" content={imageAlt} /> : null}

    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImageUrl ? <meta name="twitter:image" content={socialImageUrl} /> : null}
    {socialImageUrl && imageAlt ? <meta name="twitter:image:alt" content={imageAlt} /> : null}
    {twitterHandle ? <meta name="twitter:site" content={twitterHandle} /> : null}

    <link rel="preconnect" href="https://res.cloudinary.com" />
    <link rel="preconnect" href="https://i.ytimg.com" />
    <link rel="preconnect" href="https://www.youtube.com" />
    <link rel="preconnect" href="https://www.youtube-nocookie.com" />
    {preloadImage ? (
      <link
        rel="preload"
        as="image"
        href={preloadImage}
        imagesrcset={preloadImageSrcset}
        imagesizes={preloadImageSizes}
        fetchpriority="high"
      />
    ) : null}

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#b8a7e2" />
    <ClientRouter />

    {jsonLdItems.map(item => <script is:inline type="application/ld+json" set:html={escapeJsonLd(item)} />)}
    <slot name="jsonLd" />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header transparentOnTop={hasTransparentHeader} transparentPaths={transparentHeaderPaths} />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
