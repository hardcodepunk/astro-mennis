---
import Layout from "../layouts/Layout.astro"
import BioWithPreview from "../components/BioWithPreview.astro"
import LogosMarquee from "../components/LogosMarquee.astro"
import TextPanel from "../components/TextPanel.astro"
import { getBioWithPreview, getSeoSettings } from "../lib/sanity.queries"
import { breadcrumbJsonLd, formatTitle, metaDescription, socialImage } from "../lib/seo"
import { cloudinaryImage, imageAttributes, safePosterUrl } from "../lib/media"

const aboutDoc = await getBioWithPreview()
const seoSettings = await getSeoSettings()

const DEFAULT_HERO_MP4 =
  "https://res.cloudinary.com/hardcodepunk/video/upload/q_auto:eco,vc_h264,ac_aac,f_mp4/v1737957147/wsuszohtmu2pks673muc.mp4"
const DEFAULT_HERO_WEBM =
  "https://res.cloudinary.com/hardcodepunk/video/upload/q_auto:eco,vc_vp9,f_webm/v1761381373/b8f7chk3u9s6jaqh4bae.webm"
const DEFAULT_HERO_POSTER =
  "https://res.cloudinary.com/hardcodepunk/video/upload/q_auto:eco,so_0,f_jpg,w_1600/v1737957147/wsuszohtmu2pks673muc.jpg"
const DEFAULT_APPROACH = {
  kicker: "Approach",
  title: "Clean frames. Strong pacing. Calm process.",
  body: [
    "I make visual work that feels sharp, deliberate and human. The focus is on tone, movement and structure, with a process that stays clear from first idea to final delivery.",
    "That can mean branded content, campaign visuals, portraits, event films or short-form edits. The output changes depending on the project, but the standard stays the same.",
    "I care about images that carry weight without feeling overworked. Clean direction, strong editing and the right energy on set matter just as much as the final look.",
  ].join("\n\n"),
}

const heroTitle = aboutDoc?.heroTitle ?? aboutDoc?.seoH1 ?? "Filmmaking with clarity, rhythm and feel."
const heroMp4 = aboutDoc?.heroVideo?.mp4 ?? DEFAULT_HERO_MP4
const heroWebm = aboutDoc?.heroVideo?.webm ?? DEFAULT_HERO_WEBM
const heroPoster = safePosterUrl(aboutDoc?.heroVideo?.poster, DEFAULT_HERO_POSTER)
const optimizedHeroPoster = cloudinaryImage(heroPoster, 1920)
const approach = {
  kicker: aboutDoc?.approach?.kicker?.trim() || DEFAULT_APPROACH.kicker,
  title: aboutDoc?.approach?.title?.trim() || DEFAULT_APPROACH.title,
  body: aboutDoc?.approach?.body?.trim() || DEFAULT_APPROACH.body,
}
const title = formatTitle(seoSettings, seoSettings?.aboutTitle ?? "About")
const description = metaDescription(seoSettings, seoSettings?.aboutDescription)
const heroPosterImage = heroPoster.includes("/video/upload/") ? DEFAULT_HERO_POSTER : heroPoster
const image = socialImage(seoSettings, seoSettings?.aboutSocialImage ?? heroPosterImage)
const preloadHero = imageAttributes({
  src: heroPoster,
  widths: [768, 1024, 1280, 1600, 1920],
  fallbackWidth: 1920,
  sizes: "100vw",
})
const jsonLd = breadcrumbJsonLd(
  [
    { name: "Home", path: "/" },
    { name: "About", path: "/about" },
  ],
  seoSettings?.siteUrl,
)
---

<Layout
  title={title}
  description={description}
  image={image}
  imageAlt={seoSettings?.defaultSocialImageAlt}
  noindex={seoSettings?.aboutNoindex}
  siteUrl={seoSettings?.siteUrl}
  twitterHandle={seoSettings?.twitterHandle}
  jsonLd={jsonLd}
  preloadImage={preloadHero.src}
  preloadImageSrcset={preloadHero.srcset}
  preloadImageSizes={preloadHero.sizes}
>
  <main class="about-page">
    <section class="about-page__hero">
      <div class="about-page__inner about-page__hero-inner">
        <div class="about-page__hero-frame">
          <video
            class="about-page__hero-video"
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster={optimizedHeroPoster}
            width="1920"
            height="1080"
            aria-hidden="true"
          >
            {heroWebm ? <source src={heroWebm} type="video/webm" /> : null}
            {heroMp4 ? <source src={heroMp4} type="video/mp4" /> : null}
          </video>
          <div class="about-page__hero-shade" aria-hidden="true"></div>
          <div class="about-page__hero-content">
            <h1 class="about-page__title">{heroTitle}</h1>
          </div>
        </div>
      </div>
    </section>

    <BioWithPreview
      bio={aboutDoc?.bio}
      mp4={aboutDoc?.previewVideo?.mp4}
      webm={aboutDoc?.previewVideo?.webm}
      poster={aboutDoc?.previewVideo?.poster}
      mirrorLayout={aboutDoc?.mirrorLayout}
      bioTextScale={aboutDoc?.bioTextScale}
    />

    <TextPanel kicker={approach.kicker} title={approach.title} body={approach.body} />

    <LogosMarquee />
  </main>

  <style>
    .about-page {
      padding: 0 0 96px;
      background: var(--color-brand-primary);
    }

    .about-page__hero {
      padding-top: 0;
      width: 100vw;
      max-width: 100vw;
      margin-left: calc(50% - 50vw);
    }

    .about-page__inner.about-page__hero-inner {
      width: 100vw;
      max-width: none;
      padding: 0;
    }

    .about-page__hero-frame {
      position: relative;
      display: grid;
      align-items: end;
      width: 100vw;
      min-height: min(760px, 86svh);
      overflow: hidden;
      background: var(--color-brand-secondary);
      padding: clamp(1.25rem, 4vw, 3rem) 0;
    }

    .about-page__hero-video,
    .about-page__hero-shade {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .about-page__hero-video {
      object-fit: cover;
    }

    .about-page__hero-shade {
      pointer-events: none;
      background:
        linear-gradient(to top, rgba(0, 0, 0, 0.74), rgba(0, 0, 0, 0.16) 58%, rgba(0, 0, 0, 0.28)),
        linear-gradient(to right, rgba(0, 0, 0, 0.46), rgba(0, 0, 0, 0));
    }

    .about-page__hero-content {
      width: 100%;
      max-width: 72rem;
      margin: 0 auto;
      padding: 0 1rem;
      position: relative;
      z-index: 1;
    }

    .about-page__inner {
      max-width: 72rem;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .about-page__title {
      margin: 0;
      max-width: 11ch;
      font-family: var(--font-bebas, "Bebas Neue", sans-serif);
      font-size: clamp(3rem, 7.6vw, 6.2rem);
      line-height: 0.9;
      font-weight: 400;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      color: #fff;
    }

    @media (max-width: 900px) {
      .about-page__title {
        max-width: 12ch;
      }

      .about-page__hero-frame {
        min-height: 78svh;
      }
    }
  </style>
</Layout>
