---
import Layout from "../../layouts/Layout.astro"
import { getWorkBySlug, getWorks, getRecentWorks, getSeoSettings } from "../../lib/sanity.queries"
import { portableTextToHtml } from "../../lib/portableText"
import RecentWorks from "../../components/RecentWorks.astro"
import WorkMediaDisplay from "../../components/WorkMediaDisplay.astro"
import {
  breadcrumbJsonLd,
  creativeWorkJsonLd,
  socialImage,
  videoObjectJsonLd,
  workSeoDescription,
  workSeoTitle,
} from "../../lib/seo"
import { imageAttributes, youtubeId, youtubePoster } from "../../lib/media"

export async function getStaticPaths() {
  const works = await getWorks()
  return works.map(w => ({ params: { slug: w.slug } }))
}

const { slug } = Astro.params
const work = await getWorkBySlug(slug)
if (!work) throw new Error(`Work not found: ${slug}`)

const seoSettings = await getSeoSettings()
const recent = await getRecentWorks(3, slug)
const bodyHtml = portableTextToHtml(work.body)
const title = workSeoTitle(seoSettings, work)
const description = workSeoDescription(seoSettings, work)
const image = socialImage(seoSettings, work.seo?.socialImage ?? work.preview.poster)
const canonicalPath = work.seo?.canonicalUrl ?? `/works/${work.slug}`
const firstVideoId =
  work.media?.mode === "single"
    ? youtubeId(work.media.youtubeUrl)
    : work.media?.mode === "slider"
      ? youtubeId(work.media.reels?.[0])
      : undefined
const lcpImage = youtubePoster(firstVideoId) ?? work.preview.poster
const preloadHero = imageAttributes({
  src: lcpImage,
  widths: [768, 1024, 1280, 1600],
  fallbackWidth: 1280,
  sizes: "(max-width: 72rem) calc(100vw - 2rem), 72rem",
})
const jsonLd = [
  breadcrumbJsonLd(
    [
      { name: "Home", path: "/" },
      { name: "Projects", path: "/projects" },
      { name: work.category, path: `/projects/${work.categorySlug}` },
      { name: work.title, path: `/works/${work.slug}` },
    ],
    seoSettings?.siteUrl,
  ),
  creativeWorkJsonLd({
    seo: seoSettings,
    work,
    title,
    description,
    path: canonicalPath,
    image,
  }),
  ...videoObjectJsonLd({
    seo: seoSettings,
    work,
    title,
    description,
    image,
  }),
]
---

<Layout
  title={title}
  description={description}
  canonical={work.seo?.canonicalUrl}
  image={image}
  imageAlt={work.seo?.socialImageAlt ?? work.title}
  noindex={work.seo?.noindex}
  ogType="article"
  siteUrl={seoSettings?.siteUrl}
  twitterHandle={seoSettings?.twitterHandle}
  jsonLd={jsonLd}
  preloadImage={preloadHero.src}
  preloadImageSrcset={preloadHero.srcset}
  preloadImageSizes={preloadHero.sizes}
>
  <div class="page">
    <div class="page-inner ds-shell--content">
      <h1 class="page-title ds-title ds-title--work text-brand-secondary">{work.title}</h1>

      <div class="page-hero">
        <WorkMediaDisplay work={work} />
      </div>

      <div class="page-content">
        <aside class="page-meta" aria-label="Project details">
          <div class="page-meta-item">
            <div class="page-meta-label ds-meta-label">Year</div>
            <div class="page-meta-val ds-meta-value">{work.year}</div>
          </div>

          <div class="page-meta-item">
            <div class="page-meta-label ds-meta-label">Category</div>
            <a class="page-meta-val ds-meta-value page-meta-link ds-progress-link" href={`/projects/${work.categorySlug}`}>
              {work.category}
            </a>
          </div>

          <div class="page-meta-item">
            <div class="page-meta-label ds-meta-label">Client</div>
            <div class="page-meta-val ds-meta-value">{work.client}</div>
          </div>
        </aside>

        {
          work.overviewTitle || bodyHtml ? (
            <article class="page-article">
              <div class="page-article-card">
                {
                  work.overviewTitle ? (
                    <h2 class="page-overview-title ds-title ds-title--section">{work.overviewTitle}</h2>
                  ) : null
                }

                {bodyHtml ? <section class="page-body-rt ds-richtext" set:html={bodyHtml} /> : null}
              </div>
            </article>
          ) : null
        }
      </div>
    </div>
  </div>

  <RecentWorks items={recent} />

  <style>
    .page {
      padding: 28px 0 96px;
      background: var(--color-brand-primary);
    }

    .page-inner {
      margin: 4rem auto 0;
    }

    .page-title {
      margin: 0;
    }

    .page-content {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(10rem, 14rem);
      gap: clamp(2rem, 5vw, 5rem);
      align-items: start;
      margin-top: 72px;
    }

    .page-article {
      grid-column: 1;
      grid-row: 1;
      min-width: 0;
    }

    .page-article-card {
      padding: clamp(1.5rem, 4vw, 3rem);
      background: var(--color-brand-secondary);
      color: #fff;
    }

    .page-meta {
      grid-column: 2;
      grid-row: 1;
      display: grid;
      gap: 20px;
      position: sticky;
      top: 96px;
    }

    .page-meta-val {
      display: block;
      margin-top: 5px;
      color: var(--color-brand-secondary);
      letter-spacing: 0.06em;
    }


    .page-meta-link {
      width: max-content;
      max-width: 100%;
    }

    .page-meta-link:hover {
      color: var(--color-brand-secondary);
    }

    .page-hero {
      margin-top: 36px;
    }

    .page-overview-title {
      margin: 0 0 18px 0;
      color: #fff;
    }

    .page-body-rt a {
      color: #fff;
      text-decoration: underline;
      text-underline-offset: 3px;
      text-decoration-thickness: 1px;
      text-decoration-color: color-mix(in srgb, #fff 35%, transparent);
      transition:
        text-decoration-color 160ms ease,
        opacity 160ms ease;
    }

    .page-body-rt a:hover {
      text-decoration-color: color-mix(in srgb, #fff 75%, transparent);
      opacity: 1;
    }

    .page-body-rt strong {
      color: #fff;
      font-weight: 700;
    }

    .page-body-rt em {
      font-style: italic;
      opacity: 0.95;
    }

    .page-body-rt ul,
    .page-body-rt ol {
      margin: 18px 0 0 1.25rem;
      padding: 0;
    }

    .page-body-rt li {
      margin: 10px 0 0 0;
    }

    .page-body-rt blockquote {
      margin: 32px 0 0 0;
      padding: 18px 18px 18px 16px;
      border-left: 2px solid color-mix(in srgb, #fff 28%, transparent);
      background: color-mix(in srgb, #fff 8%, transparent);
      color: #fff;
    }

    .page-body-rt blockquote p {
      margin-top: 0;
    }

    .page-body-rt hr {
      border: 0;
      height: 1px;
      background: color-mix(in srgb, #fff 18%, transparent);
      margin: 44px 0;
    }

    .page-body-rt figure {
      margin: 32px 0 0 0;
    }

    .page-body-rt img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 0;
    }

    .page-body-rt figcaption {
      margin-top: 10px;
      font-size: 0.9rem;
      line-height: 1.45;
      opacity: 0.7;
    }

    .page-body-rt pre {
      margin: 28px 0 0 0;
      padding: 16px 16px;
      overflow: auto;
      border: 1px solid color-mix(in srgb, #fff 18%, transparent);
      background: color-mix(in srgb, #fff 8%, transparent);
      font-size: 0.92rem;
      line-height: 1.6;
    }

    .page-body-rt code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size: 0.95em;
    }

    .page-body-rt pre code {
      font-size: 0.92rem;
    }

    .page-body-rt table {
      width: 100%;
      border-collapse: collapse;
      margin: 28px 0 0 0;
      font-size: 0.98rem;
    }

    .page-body-rt th,
    .page-body-rt td {
      padding: 12px 12px;
      border-bottom: 1px solid color-mix(in srgb, #fff 18%, transparent);
      vertical-align: top;
    }

    .page-body-rt th {
      text-align: left;
      letter-spacing: 0.06em;
    }

    @media (max-width: 1000px) {
      .page-content {
        grid-template-columns: 1fr;
        gap: 34px;
        margin-top: 42px;
      }

      .page-article,
      .page-meta {
        grid-column: auto;
        grid-row: auto;
      }

      .page-meta {
        order: 1;
        position: static;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .page-article {
        order: 2;
      }

      .page-article-card,
      .page-body-rt {
        max-width: none;
      }
    }

    @media (max-width: 700px) {
      .page-meta {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
      }

      .page-meta-val {
        font-size: 1rem;
        letter-spacing: 0.06em;
      }
    }
  </style>
</Layout>
