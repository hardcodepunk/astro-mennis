---
import Layout from "../layouts/Layout.astro"
import Videohero from "../components/CinematicHero.astro"
import TextPanel from "../components/TextPanel.astro"
import ContactReasons from "../components/ContactReasons.astro"
import { getFeaturedWorks, getSeoSettings, getSiteSettings } from "../lib/sanity.queries"
import FeaturedWorks from "../components/FeaturedWorks.astro"
import { formatTitle, metaDescription, organizationJsonLd, personJsonLd, socialImage, websiteJsonLd } from "../lib/seo"
import { imageAttributes, safePosterUrl } from "../lib/media"

const featuredWorks = await getFeaturedWorks(3)
const siteSettings = await getSiteSettings()
const seoSettings = await getSeoSettings()
const DEFAULT_WORKFLOW_PANEL = {
  kicker: "Workflow",
  title: "Playful process, bold ideas, thoughtful results",
  body: [
    "We live in a world of acceleration, chasing the end goal, forgetting to enjoy the ride. At De Mennis, we slow down just enough to capture the magic in between: the boldness, the play, the small details that get lost when there is no room to breathe.",
    "We believe that when passionate people come together and actually enjoy the process, something extraordinary happens.",
    "And what cannot be put into words, we put into visuals.",
  ].join("\n\n"),
  mirrorLayout: false,
}
const DEFAULT_CONTACT_REASONS = {
  kicker: "What to contact me for",
  title: "Built for bold projects with movement, edge and energy.",
  items: [
    "Edgy & daring branding: commercials and promos that break the rules.",
    "Lifestyle & community culture: highlighting the people, the movement, and the vibe behind your brand.",
    "High-motion content: music videos, sports, and events that require speed, flow, and kinetic energy.",
    "Freelance rollerblade camera operator & editor.",
    "Aerial filmography.",
    "Ideas.",
  ],
}
const seoH1 = seoSettings?.homeH1 ?? siteSettings?.homeSeoH1 ?? "De Mennis"
const heroSettings = siteSettings?.videoHero
const workflowPanel = {
  kicker: siteSettings?.workflowPanel?.kicker?.trim() || DEFAULT_WORKFLOW_PANEL.kicker,
  title: siteSettings?.workflowPanel?.title?.trim() || DEFAULT_WORKFLOW_PANEL.title,
  body: siteSettings?.workflowPanel?.body?.trim() || DEFAULT_WORKFLOW_PANEL.body,
  mirrorLayout: siteSettings?.workflowPanel?.mirrorLayout ?? DEFAULT_WORKFLOW_PANEL.mirrorLayout,
}
const contactReasonItems = siteSettings?.contactReasons?.items?.map(item => item.trim()).filter(Boolean)
const contactReasons = {
  kicker: siteSettings?.contactReasons?.kicker?.trim() || DEFAULT_CONTACT_REASONS.kicker,
  title: siteSettings?.contactReasons?.title?.trim() || DEFAULT_CONTACT_REASONS.title,
  items: contactReasonItems?.length ? contactReasonItems : DEFAULT_CONTACT_REASONS.items,
}
const heroPoster = heroSettings?.poster ? safePosterUrl(heroSettings.poster, featuredWorks[0]?.preview.poster ?? "") : undefined
const title = formatTitle(seoSettings, seoSettings?.homeTitle ?? "De Mennis", true)
const description = metaDescription(seoSettings, seoSettings?.homeDescription)
const image = socialImage(seoSettings, seoSettings?.homeSocialImage ?? heroPoster ?? featuredWorks[0]?.preview.poster)
const preloadHero = imageAttributes({
  src: heroPoster,
  widths: [768, 1024, 1280, 1600, 1920],
  fallbackWidth: 1920,
  sizes: "100vw",
})
const jsonLd = [websiteJsonLd(seoSettings), organizationJsonLd(seoSettings), personJsonLd(seoSettings)]
---

<Layout
  title={title}
  description={description}
  image={image}
  imageAlt={seoSettings?.defaultSocialImageAlt}
  noindex={seoSettings?.homeNoindex}
  siteUrl={seoSettings?.siteUrl}
  twitterHandle={seoSettings?.twitterHandle}
  jsonLd={jsonLd}
  preloadImage={preloadHero.src}
  preloadImageSrcset={preloadHero.srcset}
  preloadImageSizes={preloadHero.sizes}
>
  <h1 class="sr-only">{seoH1}</h1>

  <Videohero
    mp4={heroSettings?.mp4}
    webm={heroSettings?.webm}
    poster={heroSettings?.poster}
    caption={heroSettings?.caption}
    captionTextScale={heroSettings?.captionTextScale}
    captionUppercase={heroSettings?.captionUppercase}
    minRevealMs={600}
  />

  <TextPanel
    kicker={workflowPanel.kicker}
    title={workflowPanel.title}
    body={workflowPanel.body}
    mirrorLayout={workflowPanel.mirrorLayout}
    fullWidth
    flushTop
  />

  <ContactReasons kicker={contactReasons.kicker} title={contactReasons.title} items={contactReasons.items} />

  <FeaturedWorks items={featuredWorks} />
</Layout>
