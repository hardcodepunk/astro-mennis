---
import Layout from "../layouts/Layout.astro"
import Videohero from "../components/CinematicHero.astro"
import LogosMarquee from "../components/LogosMarquee.astro"
import { getFeaturedWorks } from "../lib/sanity.queries"
import FeaturedWorks from "../components/FeaturedWorks.astro"

const featuredWorks = await getFeaturedWorks(3)
---

<Layout>
  <Videohero
    title="Mennis"
    subtitle="Director / Editor. Fast, clean, story-first."
    primaryHref="/portfolio"
    primaryLabel="View Portfolio"
    secondaryHref="/contact"
    secondaryLabel="Book a Project"
    minRevealMs={600}
  />

  <LogosMarquee />

  <FeaturedWorks items={featuredWorks} />
</Layout>
