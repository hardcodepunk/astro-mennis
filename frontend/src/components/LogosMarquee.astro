---
import { getLogoMarquee } from "../lib/sanity.queries"
import { imageAttributes } from "../lib/media"

const data = await getLogoMarquee()
const items = data?.logos ?? []

const { speed = 28, height = 96 } = Astro.props

const duration = Math.max(8, Number(speed) || 28)
const h = Math.max(48, Number(height) || 96)
const safeItems = items.filter(i => i?.image?.url)
const repeatCount = 12
const repeatedRows = Array.from({ length: repeatCount }, (_, index) => index)
const marqueeShift = `${-100 / repeatCount}%`
const logoImage = (url: string) =>
  imageAttributes({
    src: url,
    widths: [160, 240, 320, 480],
    fallbackWidth: 320,
    sizes: "220px",
  })
const logoItems = safeItems.map(item => ({
  ...item,
  imageAttrs: logoImage(item.image.url),
}))
---

{
  safeItems.length > 0 && (
    <section class="lm" style={`--lm-duration:${duration}s;--lm-h:${h}px;--lm-shift:${marqueeShift};`}>
      <div class="lm-mask">
        <div class="lm-track" aria-label="Client logos">
          {repeatedRows.map(rowIndex => (
            <ul class="lm-row" aria-hidden={rowIndex > 0 ? "true" : undefined}>
              {logoItems.map(item => (
                <li class="lm-item">
                  <img
                    class="lm-logo"
                    src={item.imageAttrs.src}
                    srcset={item.imageAttrs.srcset}
                    sizes={item.imageAttrs.sizes}
                    width={item.image.dimensions?.width ?? 220}
                    height={item.image.dimensions?.height ?? Math.round(h * 0.68)}
                    alt={rowIndex === 0 ? item.alt || item.name || "Client logo" : ""}
                    loading="lazy"
                    decoding="async"
                  />
                </li>
              ))}
            </ul>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .lm {
    width: 100%;
    padding: 40px 0;
  }

  .lm-mask {
    height: var(--lm-h);
    display: flex;
    align-items: center;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }

  .lm-track {
    display: flex;
    width: max-content;
    will-change: transform;
    animation: lm-marquee var(--lm-duration) linear infinite;
  }

  .lm-row {
    display: flex;
    align-items: center;
    gap: 72px;
    padding-right: 72px;
    list-style: none;
    margin: 0;
    padding-left: 0;
    flex: 0 0 auto;
  }

  .lm-item {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .lm-logo {
    display: block;
    height: calc(var(--lm-h) * 0.68);
    width: auto;
    max-width: 220px;
    object-fit: contain;
    filter: grayscale(1) saturate(0);
  }

  @keyframes lm-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(var(--lm-shift));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lm-track {
      animation: none;
      transform: none;
    }

    .lm-mask {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }
</style>
