---
type Props = {
  sentences: string[]
  mailSentence: string
  email: string
}

const { sentences, mailSentence, email } = Astro.props as Props
const firstSentence = sentences[0] ?? ""
const mailHref = `mailto:${email}`
---

<section class="contact-page">
  <div class="contact-page__inner">
    <div class="contact-page__details">
      <div class="contact-page__intro">
        <p class="contact-page__meta">
          <span class="contact-page__meta-label">Based in</span>
          <strong>Gent, Belgium</strong>
        </p>

        <a class="contact-page__meta contact-page__mail" href={mailHref}>
          <span class="contact-page__meta-label">{mailSentence}</span>
          <strong>{email}</strong>
        </a>
      </div>
    </div>

    <div class="contact-page__headline" aria-live="polite">
      <span data-contact-typewriter>{firstSentence}</span><span class="contact-page__cursor" aria-hidden="true">|</span>
    </div>
  </div>
</section>

<script is:inline define:vars={{ sentences }}>
  ;(() => {
    const bootTypewriter = () => {
      const target = document.querySelector("[data-contact-typewriter]")
      if (!(target instanceof HTMLElement) || target.dataset.typewriterReady === "true") return

      const values = Array.isArray(sentences)
        ? sentences.map(value => String(value || "").trim()).filter(Boolean)
        : []

      if (values.length <= 1 || window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        target.textContent = values[0] || target.textContent || ""
        return
      }

      target.dataset.typewriterReady = "true"

      let sentenceIndex = 0
      let charIndex = values[0].length
      let deleting = true
      let timeoutId = 0

      const tick = () => {
        const current = values[sentenceIndex] || ""

        if (deleting) {
          charIndex -= 1
          target.textContent = current.slice(0, Math.max(0, charIndex))

          if (charIndex <= 0) {
            deleting = false
            sentenceIndex = (sentenceIndex + 1) % values.length
          }
        } else {
          const next = values[sentenceIndex] || ""
          charIndex += 1
          target.textContent = next.slice(0, charIndex)

          if (charIndex >= next.length) {
            deleting = true
          }
        }

        const atFullSentence = deleting && charIndex >= (values[sentenceIndex] || "").length
        const atEmptySentence = !deleting && charIndex <= 0
        const delay = atFullSentence ? 1400 : atEmptySentence ? 240 : deleting ? 32 : 58
        timeoutId = window.setTimeout(tick, delay)
      }

      timeoutId = window.setTimeout(tick, 1200)

      document.addEventListener(
        "astro:before-swap",
        () => {
          window.clearTimeout(timeoutId)
        },
        { once: true },
      )
    }

    bootTypewriter()
    document.addEventListener("astro:page-load", bootTypewriter)
    document.addEventListener("astro:after-swap", bootTypewriter)
  })()
</script>

<style>
  .contact-page {
    min-height: 100svh;
    display: grid;
    align-items: center;
    padding: clamp(5rem, 10vh, 7rem) 1.5rem clamp(2rem, 6vh, 4rem);
    background: transparent;
    color: var(--color-brand-secondary);
  }

  .contact-page__inner {
    width: min(100%, 90rem);
    margin: 0 auto;
    display: grid;
    gap: clamp(2rem, 5vh, 3.25rem);
  }

  .contact-page__headline {
    min-height: clamp(10rem, 28vw, 20rem);
    max-width: 68rem;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      sans-serif;
    font-size: clamp(2.7rem, 7vw, 7rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: 0;
  }

  .contact-page__cursor {
    display: inline-block;
    margin-left: 0.08em;
    animation: contact-cursor 700ms steps(2, start) infinite;
  }

  .contact-page__details {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
  }

  .contact-page__intro {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.85rem, 2vw, 1.15rem);
    align-items: stretch;
  }

  .contact-page__meta {
    display: grid;
    gap: 0.45rem;
    align-content: start;
    min-width: min(100%, 20rem);
    margin: 0;
    padding: clamp(0.85rem, 1.7vw, 1.15rem) clamp(0.95rem, 2vw, 1.35rem);
    border: 2px solid currentColor;
    background: rgba(47, 58, 48, 0.07);
    color: var(--color-brand-secondary);
    box-shadow: 0.5rem 0.5rem 0 var(--color-brand-secondary);
    transform: translate(-0.5rem, -0.5rem);
  }

  .contact-page__meta-label {
    width: max-content;
    padding: 0.25rem 0.42rem 0.22rem;
    background: var(--color-brand-secondary);
    color: var(--color-brand-primary);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    line-height: 1;
    text-transform: uppercase;
  }

  .contact-page__meta strong {
    font-family: var(--font-bebas, "Bebas Neue", sans-serif);
    font-size: clamp(2rem, 4.4vw, 3.7rem);
    line-height: 0.9;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    overflow-wrap: anywhere;
  }

  .contact-page__mail {
    color: var(--color-brand-secondary);
    text-decoration: none;
    transition:
      background 160ms ease,
      color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .contact-page__mail:hover {
    background: var(--color-brand-secondary);
    color: var(--color-brand-primary);
    box-shadow: 0.28rem 0.28rem 0 var(--color-brand-secondary);
    transform: translate(-0.28rem, -0.28rem);
  }

  .contact-page__mail:hover .contact-page__meta-label {
    background: var(--color-brand-primary);
    color: var(--color-brand-secondary);
  }

  @keyframes contact-cursor {
    0%,
    100% {
      opacity: 1;
    }

    50% {
      opacity: 0;
    }
  }

  @media (max-width: 760px) {
    .contact-page__headline {
      min-height: 18rem;
    }

    .contact-page__details {
      align-items: flex-start;
      flex-direction: column;
    }

    .contact-page__intro {
      display: grid;
      width: 100%;
    }

    .contact-page__meta {
      transform: none;
      box-shadow: none;
    }

  }
</style>
