---
import LineBreakText from "./LineBreakText.astro"

type Props = {
  kicker?: string
  title?: string
  body?: string
  fullWidth?: boolean
  bleedBackground?: boolean
  flushTop?: boolean
  mirrorLayout?: boolean
}

const {
  kicker,
  title,
  body,
  fullWidth = false,
  bleedBackground = false,
  flushTop = false,
  mirrorLayout = false,
} = Astro.props as Props
const safeKicker = kicker?.trim() ?? ""
const safeTitle = title?.trim() ?? ""
const paragraphs = (body ?? "")
  .split(/\n{2,}/)
  .map(paragraph => paragraph.trim())
  .filter(Boolean)
const hasContent = Boolean(safeTitle || paragraphs.length)
---

{
  hasContent ? (
    <section
      class:list={[
        "tp",
        fullWidth && "is-full",
        bleedBackground && "is-bleed",
        flushTop && "is-flush",
        mirrorLayout && "is-mirrored",
        !safeKicker && !safeTitle && "is-copy-only",
        !paragraphs.length && "is-heading-only",
      ]}
    >
      <div class="tp-inner ds-split-grid ds-shell">
        <div class="tp-col">
          {safeKicker ? <p class="tp-kicker ds-kicker">{safeKicker}</p> : null}
          {safeTitle ? (
            <h2 class="tp-title ds-title ds-title--xl"><LineBreakText text={safeTitle} /></h2>
          ) : null}
        </div>

        {paragraphs.length ? (
          <div class="tp-copy ds-copy-body">
            {paragraphs.map(paragraph => <p>{paragraph}</p>)}
          </div>
        ) : null}
      </div>
    </section>
  ) : null
}

<style>
    .tp {
      padding-top: 32px;
    }

    .tp.is-flush {
      padding-top: 0;
    }

    .tp.is-full {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      background: transparent;
    }

    .tp.is-bleed {
      width: 100vw;
      margin-left: calc(50% - 50vw);
      background: var(--color-brand-secondary);
    }

    .tp-inner {
      max-width: 72rem;
      padding: clamp(1.5rem, 4vw, 3rem);
      background: var(--color-brand-secondary);
      color: #fff;
    }

    .tp.is-full .tp-inner {
      max-width: 90rem;
      background: transparent;
      color: var(--color-brand-secondary);
      padding-block: clamp(3rem, 7vw, 6rem);
      padding-inline: clamp(1.5rem, 5vw, 4rem);
    }

    .tp.is-bleed .tp-inner {
      max-width: 90rem;
      background: transparent;
      padding-block: clamp(3rem, 7vw, 6rem);
      padding-inline: clamp(1.5rem, 5vw, 4rem);
    }

    .tp.is-full .tp-kicker,
    .tp.is-full .tp-title,
    .tp.is-full .tp-copy {
      color: var(--color-brand-secondary);
    }

    .tp.is-mirrored .tp-col {
      order: 2;
    }

    .tp.is-mirrored .tp-copy {
      order: 1;
    }

    .tp.is-copy-only .tp-inner,
    .tp.is-heading-only .tp-inner {
      grid-template-columns: 1fr;
    }

    .tp.is-copy-only .tp-col {
      display: none;
    }

    .tp-kicker {
      margin: 0 0 10px 0;
      color: rgba(255, 255, 255, 0.68);
    }

    .tp-title {
      color: #fff;
    }

    .tp-copy {
      max-width: 42rem;
      color: #fff;
    }

    .tp-copy p {
      margin: 0;
    }

    .tp-copy p + p {
      margin-top: 18px;
    }

    @media (max-width: 900px) {
      .tp-inner {
        grid-template-columns: 1fr;
        gap: 24px;
      }
    }
  </style>
