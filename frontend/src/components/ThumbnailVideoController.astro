<script>
  ;(() => {
    const win = window as Window & { __thumbnailVideoControllerBooted?: boolean }
    if (win.__thumbnailVideoControllerBooted) return
    win.__thumbnailVideoControllerBooted = true

    const prepareVideo = (video: HTMLVideoElement) => {
      video.muted = true
      video.defaultMuted = true
      video.playsInline = true
      video.setAttribute("muted", "")
      video.setAttribute("playsinline", "")
      video.setAttribute("webkit-playsinline", "")
    }

    const initThumbnailVideos = () => {
      const finePointer = window.matchMedia("(hover: hover) and (pointer: fine)")
      const motionAllowed = !window.matchMedia("(prefers-reduced-motion: reduce)").matches
      const desktopViewport = window.matchMedia("(min-width: 768px)").matches
      const items = document.querySelectorAll("[data-thumbnail-card]")

      items.forEach(item => {
        if (!(item instanceof HTMLElement) || item.dataset.videoReady === "true") return
        item.dataset.videoReady = "true"

        const block = item.querySelector("[data-thumbnail-video]")
        if (!(block instanceof HTMLElement)) return

        const video = block.querySelector("video")
        if (!(video instanceof HTMLVideoElement)) return
        prepareVideo(video)

        const sources = Array.from(video.querySelectorAll("source"))
        const shouldAutoplay = block.dataset.autoplay === "true"
        let hydrated = false
        let playing = false
        let pendingStart = false

        const hydrate = () => {
          if (hydrated) return
          hydrated = true
          sources.forEach(s => {
            const src = s.getAttribute("data-src")
            if (src) s.setAttribute("src", src)
          })
          video.load()
        }

        const scheduleStart = () => {
          if (pendingStart || playing) return
          pendingStart = true

          const retry = () => {
            pendingStart = false
            start()
          }

          video.addEventListener("loadeddata", retry, { once: true })
          video.addEventListener("canplay", retry, { once: true })
          window.setTimeout(retry, 160)
        }

        const start = async () => {
          if (playing) return
          pendingStart = false
          hydrate()
          prepareVideo(video)

          try {
            await video.play()
            playing = true
            block.classList.add("is-playing")
          } catch {
            playing = false
            block.classList.remove("is-playing")
            if (video.readyState < HTMLMediaElement.HAVE_CURRENT_DATA) scheduleStart()
          }
        }

        const stop = () => {
          playing = false
          pendingStart = false
          video.pause()
          try {
            video.currentTime = 0
          } catch {}
          block.classList.remove("is-playing")
        }

        if (!motionAllowed) return

        if (shouldAutoplay) {
          video.preload = "metadata"
          start()
          window.addEventListener("pageshow", start)
          document.addEventListener("visibilitychange", () => {
            if (!document.hidden) start()
          })
          return
        }

        if (!desktopViewport || !finePointer.matches) return

        item.addEventListener("pointerenter", start)
        item.addEventListener("pointerleave", stop)
        item.addEventListener("focusin", start)
        item.addEventListener("focusout", stop)
      })
    }

    initThumbnailVideos()
    document.addEventListener("astro:page-load", initThumbnailVideos)
    document.addEventListener("astro:after-swap", initThumbnailVideos)
  })()
</script>
