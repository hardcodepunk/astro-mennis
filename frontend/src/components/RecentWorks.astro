---
import ThumbnailVideoController from "./ThumbnailVideoController.astro"
import WorkThumbnailCard from "./WorkThumbnailCard.astro"
import type { WorkItem } from "../lib/sanity.queries"

const { items = [] } = Astro.props as { items: WorkItem[] }
---

<section class="rw">
  <div class="rw-inner">
    <h2 class="rw-title">RECENT WORK</h2>

    <div class="rw-grid">
      {items.map(work => <WorkThumbnailCard work={work} headingTag="h3" />)}
    </div>
  </div>

  <ThumbnailVideoController />

  <style>
    .rw {
      padding: 88px 0;
      font-family: var(--font-bebas, "Bebas Neue", sans-serif);
    }

    .rw-inner {
      max-width: 96rem;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .rw-title {
      margin: 0 0 44px 0;
      font-size: clamp(2.4rem, 6vw, 5rem);
      line-height: 0.9;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }

    .rw-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }

    @media (max-width: 1000px) {
      .rw-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 700px) {
      .rw-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>
