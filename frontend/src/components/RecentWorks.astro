---
import WorkThumbnailCard from "./WorkThumbnailCard.astro"
import type { WorkItem } from "../lib/sanity.queries"

const { items = [] } = Astro.props as { items: WorkItem[] }
---

<section class="rw">
  <div class="rw-inner ds-shell--wide">
    <h2 class="rw-title ds-title ds-title--large">Keep on watching</h2>

    <div class="rw-grid">
      {items.map(work => <WorkThumbnailCard work={work} headingTag="h3" />)}
    </div>
  </div>

  <style>
    .rw {
      padding: 88px 0;
    }

    .rw-inner {
      margin: 0 auto;
      max-width: 100%;
    }

    .rw-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }

    @media (max-width: 1000px) {
      .rw-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 700px) {
      .rw-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>
