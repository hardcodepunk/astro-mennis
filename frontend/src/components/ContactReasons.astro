---
import LineBreakText from "./LineBreakText.astro"

type Props = {
  kicker?: string
  title?: string
  items: string[]
  mirrorLayout?: boolean
}

const { kicker, title, items, mirrorLayout = false } = Astro.props as Props
const safeKicker = kicker?.trim() ?? ""
const safeTitle = title?.trim() ?? ""
const safeItems = items.map(item => item.trim()).filter(Boolean)
const hasHeading = Boolean(safeKicker || safeTitle)
---

{
  safeItems.length ? (
    <section class:list={["cr", mirrorLayout && "is-mirrored"]} aria-labelledby={safeTitle ? "contact-reasons-title" : undefined}>
      <div class:list={["cr-inner ds-split-grid ds-shell", !hasHeading && "is-list-only"]}>
        {
          hasHeading ? (
            <div class="cr-heading">
              {safeKicker ? <p class="cr-kicker ds-kicker">{safeKicker}</p> : null}
              {safeTitle ? (
                <h2 id="contact-reasons-title" class="cr-title ds-title ds-title--xl">
                  <LineBreakText text={safeTitle} />
                </h2>
              ) : null}
            </div>
          ) : null
        }

        <ul class="cr-list ds-copy-list">
          {safeItems.map(item => (
            <li class="cr-item">
              <span class="cr-dot" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ) : null
}

<style>
  .cr {
    padding: 32px 0 clamp(3rem, 7vw, 6rem);
  }

  .cr-inner {
    max-width: 90rem;
    padding-block: clamp(1.5rem, 4vw, 3rem);
    padding-inline: clamp(1.5rem, 5vw, 4rem);
    color: var(--color-brand-secondary);
  }

  .cr-inner.is-list-only {
    grid-template-columns: 1fr;
    padding-top: 0;
  }

  .cr.is-mirrored .cr-heading {
    order: 2;
  }

  .cr.is-mirrored .cr-list {
    order: 1;
  }

  .cr-kicker {
    margin: 0 0 10px 0;
    color: var(--color-brand-secondary);
    opacity: 0.68;
  }

  .cr-title {
    max-width: 12ch;
  }

  .cr-list {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cr-item {
    display: grid;
    grid-template-columns: 0.7rem minmax(0, 1fr);
    gap: 0.85rem;
    align-items: start;
  }

  .cr-dot {
    width: 0.45rem;
    height: 0.45rem;
    margin-top: 0.62em;
    background: var(--color-brand-secondary);
  }

  @media (max-width: 900px) {
    .cr-inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .cr-title {
      max-width: 14ch;
    }
  }
</style>
