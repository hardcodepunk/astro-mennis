---
import LineBreakText from "./LineBreakText.astro"

type Props = {
  kicker?: string
  title?: string
  items: string[]
  mirrorLayout?: boolean
}

const { kicker, title, items, mirrorLayout = false } = Astro.props as Props
const safeKicker = kicker?.trim() ?? ""
const safeTitle = title?.trim() ?? ""
const safeItems = items.map(item => item.trim()).filter(Boolean)
const hasHeading = Boolean(safeKicker || safeTitle)
---

{
  safeItems.length ? (
    <section class:list={["cr", mirrorLayout && "is-mirrored"]} aria-labelledby={safeTitle ? "contact-reasons-title" : undefined}>
      <div class:list={["cr-inner", !hasHeading && "is-list-only"]}>
        {
          hasHeading ? (
            <div class="cr-heading">
              {safeKicker ? <p class="cr-kicker">{safeKicker}</p> : null}
              {safeTitle ? <h2 id="contact-reasons-title" class="cr-title"><LineBreakText text={safeTitle} /></h2> : null}
            </div>
          ) : null
        }

        <ul class="cr-list">
          {safeItems.map(item => (
            <li class="cr-item">
              <span class="cr-dot" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ) : null
}

<style>
  .cr {
    padding: 32px 0 clamp(3rem, 7vw, 6rem);
  }

  .cr-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
    max-width: 90rem;
    margin: 0 auto;
    padding-block: clamp(1.5rem, 4vw, 3rem);
    padding-inline: clamp(1.5rem, 5vw, 4rem);
    color: var(--color-brand-secondary);
  }

  .cr-inner.is-list-only {
    grid-template-columns: 1fr;
    padding-top: 0;
  }

  .cr.is-mirrored .cr-heading {
    order: 2;
  }

  .cr.is-mirrored .cr-list {
    order: 1;
  }

  .cr-kicker {
    margin: 0 0 10px 0;
    color: var(--color-brand-secondary);
    font-size: 0.95rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.68;
  }

  .cr-title {
    margin: 0;
    max-width: 12ch;
    font-family: var(--font-bebas, "Bebas Neue", sans-serif);
    font-size: clamp(2.2rem, 4.6vw, 4.2rem);
    line-height: 0.92;
    font-weight: 400;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    overflow-wrap: break-word;
  }

  .cr-list {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      sans-serif;
    font-size: clamp(1rem, 1.7vw, 1.25rem);
    line-height: 1.55;
    font-weight: 600;
  }

  .cr-item {
    display: grid;
    grid-template-columns: 0.7rem minmax(0, 1fr);
    gap: 0.85rem;
    align-items: start;
  }

  .cr-dot {
    width: 0.45rem;
    height: 0.45rem;
    margin-top: 0.62em;
    background: var(--color-brand-secondary);
  }

  @media (max-width: 900px) {
    .cr-inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .cr-title {
      max-width: 14ch;
    }
  }
</style>
