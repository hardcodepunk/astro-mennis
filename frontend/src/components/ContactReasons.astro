---
type Props = {
  kicker?: string
  title: string
  items: string[]
}

const { kicker, title, items } = Astro.props as Props
const safeItems = items.map(item => item.trim()).filter(Boolean)
---

{
  safeItems.length ? (
    <section class="cr" aria-labelledby="contact-reasons-title">
      <div class="cr-inner">
        <div class="cr-heading">
          {kicker ? <p class="cr-kicker">{kicker}</p> : null}
          <h2 id="contact-reasons-title" class="cr-title">{title}</h2>
        </div>

        <ul class="cr-list">
          {safeItems.map(item => (
            <li class="cr-item">
              <span class="cr-dot" aria-hidden="true"></span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ) : null
}

<style>
  .cr {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    padding: 0 clamp(1rem, 4vw, 4rem) clamp(3rem, 7vw, 6rem);
  }

  .cr-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
    max-width: 90rem;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem);
    background: var(--color-brand-secondary);
    color: #fff;
  }

  .cr-kicker {
    margin: 0 0 10px 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 0.95rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .cr-title {
    margin: 0;
    max-width: 12ch;
    font-family: var(--font-bebas, "Bebas Neue", sans-serif);
    font-size: clamp(2.2rem, 4.6vw, 4.2rem);
    line-height: 0.92;
    font-weight: 400;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    overflow-wrap: break-word;
  }

  .cr-list {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
    font-family:
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      sans-serif;
    font-size: clamp(1rem, 1.7vw, 1.25rem);
    line-height: 1.55;
    font-weight: 600;
  }

  .cr-item {
    display: grid;
    grid-template-columns: 0.7rem minmax(0, 1fr);
    gap: 0.85rem;
    align-items: start;
  }

  .cr-dot {
    width: 0.45rem;
    height: 0.45rem;
    margin-top: 0.62em;
    background: #fff;
  }

  @media (max-width: 900px) {
    .cr-inner {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .cr-title {
      max-width: 14ch;
    }
  }
</style>
