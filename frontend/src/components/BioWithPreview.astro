---
import { defaultHeroMedia } from "../lib/media"

import VideoPreview from "./VideoPreview.astro"

const DEFAULT_BIO = `I shoot clean, cinematic video for brands and people who care about craft.
Fast turnaround, calm sets, sharp edits. Commercials, social cuts, event recaps,
and story-driven pieces done properly.`

const DEFAULT_MP4 =
  defaultHeroMedia.mp4
const DEFAULT_WEBM =
  defaultHeroMedia.webm
const DEFAULT_POSTER =
  defaultHeroMedia.poster

const props = Astro.props as {
  bio?: string
  mp4?: string
  webm?: string
  poster?: string
  mirrorLayout?: boolean
  bioTextScale?: number
}

const bio = props.bio ?? DEFAULT_BIO
const mp4 = props.mp4 ?? DEFAULT_MP4
const webm = props.webm ?? DEFAULT_WEBM
const poster = props.poster ?? DEFAULT_POSTER
const mirrorLayout = props.mirrorLayout ?? false
const textScale = Math.min(1.4, Math.max(0.5, (props.bioTextScale ?? 100) / 100))
---

<section class:list={["bp", mirrorLayout && "is-mirrored"]} style={`--bio-scale: ${textScale};`}>
  <div class="bp-inner">
    <div class="bp-left">
      <p class="bp-bio ds-copy ds-copy--strong">{bio}</p>
    </div>

    <div class="bp-right">
      <VideoPreview mp4={mp4} webm={webm} poster={poster} />
    </div>
  </div>

  <style>
    .bp {
      padding: 72px 0;
    }

    .bp-inner {
      max-width: 90rem;
      margin: 0 auto;
      padding: 0 clamp(1.5rem, 5vw, 4rem);
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 48px;
      align-items: center;
    }

    .bp.is-mirrored .bp-left {
      order: 2;
    }

    .bp.is-mirrored .bp-right {
      order: 1;
    }

    .bp-bio {
      margin: 0;
      max-width: 42rem;
      font-size: clamp(calc(1rem * var(--bio-scale)), calc(1.7vw * var(--bio-scale)), calc(1.25rem * var(--bio-scale)));
      line-height: 1.65;
      letter-spacing: 0;
      color: var(--color-brand-secondary);
      white-space: pre-line;
    }

    @media (max-width: 900px) {
      .bp-inner {
        grid-template-columns: 1fr;
      }
    }
  </style>
</section>
