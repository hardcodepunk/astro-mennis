---
import LineBreakText from "./LineBreakText.astro"
import VideoPreview from "./VideoPreview.astro"

const DEFAULT_BIO = `I SHOOT CLEAN, CINEMATIC VIDEO FOR BRANDS AND PEOPLE WHO CARE ABOUT CRAFT.
FAST TURNAROUND, CALM SETS, SHARP EDITS. COMMERCIALS, SOCIAL CUTS, EVENT RECAPS,
AND STORY-DRIVEN PIECES — DONE PROPERLY.`

const DEFAULT_MP4 =
  "https://res.cloudinary.com/hardcodepunk/video/upload/q_auto:eco,vc_h264,ac_aac,f_mp4/v1737957147/wsuszohtmu2pks673muc.mp4"
const DEFAULT_WEBM =
  "https://res.cloudinary.com/hardcodepunk/video/upload/q_auto:eco,vc_vp9,f_webm/v1761381373/b8f7chk3u9s6jaqh4bae.webm"
const DEFAULT_POSTER =
  "https://res.cloudinary.com/hardcodepunk/video/upload/q_auto:eco,so_0,f_jpg,w_1600/v1737957147/wsuszohtmu2pks673muc.jpg"

const props = Astro.props as {
  bio?: string
  sectionKicker?: string
  sectionTitle?: string
  mp4?: string
  webm?: string
  poster?: string
  mirrorLayout?: boolean
  bioTextScale?: number
  bioUppercase?: boolean
}

const bio = props.bio ?? DEFAULT_BIO
const mp4 = props.mp4 ?? DEFAULT_MP4
const webm = props.webm ?? DEFAULT_WEBM
const poster = props.poster ?? DEFAULT_POSTER
const mirrorLayout = props.mirrorLayout ?? false
const textScale = Math.min(1.4, Math.max(0.5, (props.bioTextScale ?? 100) / 100))
const bioUppercase = props.bioUppercase ?? true
const sectionKicker = props.sectionKicker?.trim() ?? ""
const sectionTitle = props.sectionTitle?.trim() ?? ""
const hasSectionIntro = Boolean(sectionKicker || sectionTitle)
---

<section class:list={["bp", mirrorLayout && "is-mirrored"]} style={`--bio-scale: ${textScale};`}>
  {
    hasSectionIntro ? (
      <div class="bp-section-intro">
        {sectionKicker ? <p class="bp-kicker">{sectionKicker}</p> : null}
        {sectionTitle ? <h2 class="bp-title"><LineBreakText text={sectionTitle} /></h2> : null}
      </div>
    ) : null
  }

  <div class="bp-inner">
    <div class="bp-left">
      <p class:list={["bp-bio", bioUppercase && "is-uppercase"]}>{bio}</p>
    </div>

    <div class="bp-right">
      <VideoPreview mp4={mp4} webm={webm} poster={poster} />
    </div>
  </div>

  <style>
    .bp {
      padding: 72px 0;
    }
    .bp-section-intro {
      max-width: 72rem;
      margin: 0 auto clamp(2rem, 5vw, 3rem);
      padding: 0 1rem;
    }

    .bp-kicker {
      margin: 0 0 10px 0;
      color: var(--color-brand-secondary);
      font-size: 0.95rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      opacity: 0.68;
    }

    .bp-title {
      margin: 0;
      max-width: 12ch;
      font-family: var(--font-bebas, "Bebas Neue", sans-serif);
      font-size: clamp(2rem, 4vw, 3.4rem);
      line-height: 0.92;
      font-weight: 400;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: var(--color-brand-secondary);
      overflow-wrap: break-word;
    }

    .bp-inner {
      max-width: 72rem;
      margin: 0 auto;
      padding: 0 1rem;
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 48px;
      align-items: center;
    }

    .bp.is-mirrored .bp-left {
      order: 2;
    }

    .bp.is-mirrored .bp-right {
      order: 1;
    }

    .bp-bio {
      margin: 0;
      font-family: var(--font-display, "Bebas Neue", sans-serif);
      font-size: clamp(calc(2.1rem * var(--bio-scale)), calc(4vw * var(--bio-scale)), calc(3.2rem * var(--bio-scale)));
      line-height: 1.05;
      letter-spacing: 0.02em;
      color: var(--color-brand-secondary);
      max-width: 28ch;
      white-space: pre-line;
    }

    .bp-bio.is-uppercase {
      text-transform: uppercase;
    }
    @media (max-width: 900px) {
      .bp-inner {
        grid-template-columns: 1fr;
      }
      .bp-bio {
        max-width: 34ch;
      }
    }
  </style>
</section>
