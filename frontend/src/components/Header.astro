---
const NAV = [
  { label: "Projects", href: "/projects" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/#contact" },
]

const { transparentOnTop = false, transparentPaths = [] } = Astro.props
---

<header class:list={["site-header fixed top-0 z-50 w-full", !transparentOnTop && "is-solid"]} data-header>
  <div class="header-bg" aria-hidden="true"></div>

  <div class="relative flex h-16 items-center justify-between px-6">
    <a
      href="/"
      class="brand font-display text-2xl tracking-widest transition-colors"
      data-brand
    >
      DE MENNIS
    </a>

    <nav class="desktop-nav hidden md:flex items-center gap-8 text-sm font-bold">
      <a href="/projects" class="desktop-link transition-colors">Projects</a>
      <a href="/about" class="desktop-link transition-colors">About</a>
      <a href="/#contact" class="desktop-link transition-colors">Contact</a>
    </nav>

    <button
      type="button"
      class="md:hidden inline-flex items-center justify-center p-2"
      aria-label="Open menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
      data-menu-button
    >
      <span class="hamburger" aria-hidden="true">
        <span class="hamburger__bar"></span>
        <span class="hamburger__bar"></span>
        <span class="hamburger__bar"></span>
      </span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="mobile-menu" aria-hidden="true" data-menu-overlay>
  <div class="mobile-menu__backdrop" data-menu-backdrop></div>

  <div class="mobile-menu__panel" role="dialog" aria-modal="true" aria-label="Site menu">
    <nav class="mobile-menu__nav px-6">
      <div class="mobile-menu__stack font-display text-2xl tracking-widest">
        {
          NAV.map(item => (
            <a href={item.href} class="mobile-link" data-menu-link>
              {item.label}
            </a>
          ))
        }
      </div>
    </nav>
  </div>
</div>

<style>
  .site-header {
    will-change: transform;
  }

  .header-bg {
    position: absolute;
    inset: 0;
    background: var(--color-brand-primary);
    opacity: 0;
    transform: translateY(-100%);
    transition:
      transform 240ms ease,
      opacity 240ms ease;
    will-change: transform, opacity;
    z-index: 0;
  }

  .site-header.is-solid .header-bg {
    transform: translateY(0);
    opacity: 1;
  }

  .site-header.is-menu-open {
    z-index: 80;
  }

  .brand {
    color: #fff;
  }

  .brand:hover {
    color: #fff;
    opacity: 1;
  }

  .site-header.is-solid .brand {
    color: var(--color-brand-secondary);
  }

  .site-header.is-solid .brand:hover {
    color: #fff;
  }

  .desktop-link {
    color: #fff;
  }

  .site-header.is-solid .desktop-link {
    color: var(--color-brand-secondary);
  }

  .site-header.is-solid .desktop-link:hover {
    color: #fff;
  }

  .desktop-link:hover {
    color: #fff;
  }

  .hamburger {
    width: 28px;
    height: 20px;
    display: inline-flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hamburger__bar {
    height: 3px;
    width: 100%;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 0;
    transform-origin: center;
    transition:
      transform 220ms ease,
      opacity 180ms ease,
      background-color 180ms ease;
  }

  .site-header.is-solid .hamburger__bar {
    background: var(--color-brand-secondary);
  }

  .hamburger.is-open .hamburger__bar:nth-child(1) {
    transform: translateY(8.5px) rotate(45deg);
  }

  .hamburger.is-open .hamburger__bar:nth-child(2) {
    opacity: 0;
  }

  .hamburger.is-open .hamburger__bar:nth-child(3) {
    transform: translateY(-8.5px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 70;
    pointer-events: none;
  }

  .mobile-menu__backdrop {
    position: absolute;
    inset: 0;
    background: var(--color-brand-primary);
    opacity: 1;
    transform: translateX(100%);
    transition: transform 240ms ease;
  }

  .mobile-menu__panel {
    position: relative;
    height: 100%;
    width: 100%;
    transform: translateX(100%);
    transition: transform 240ms ease;
  }

  .mobile-menu__nav {
    height: 100vh;
    display: grid;
    place-items: center;
    text-align: center;
  }

  .mobile-menu__stack {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .mobile-link {
    color: var(--color-brand-secondary);
    transition:
      color 150ms ease,
      transform 200ms ease,
      opacity 200ms ease;
    opacity: 0;
    transform: translateY(6px);
    display: flex;
    justify-content: center;
  }

  .mobile-link:hover {
    color: var(--color-brand-secondary);
    opacity: 0.8;
  }

  .mobile-menu.is-open {
    pointer-events: auto;
  }

  .mobile-menu.is-open .mobile-menu__backdrop {
    transform: translateX(0);
  }

  .mobile-menu.is-open .mobile-menu__panel {
    transform: translateX(0);
  }

  .mobile-menu.is-open .mobile-link {
    opacity: 1;
    transform: translateY(0);
  }

  .mobile-menu.is-open .mobile-link:nth-child(1) {
    transition-delay: 40ms;
  }

  .mobile-menu.is-open .mobile-link:nth-child(2) {
    transition-delay: 80ms;
  }

  .mobile-menu.is-open .mobile-link:nth-child(3) {
    transition-delay: 120ms;
  }

  .mobile-menu.is-open .mobile-link:nth-child(4) {
    transition-delay: 160ms;
  }

  @media (prefers-reduced-motion: reduce) {
    .header-bg,
    .hamburger__bar,
    .mobile-menu__backdrop,
    .mobile-menu__panel,
    .mobile-link,
    .brand,
    .desktop-link {
      transition: none !important;
    }
  }
</style>

<script is:inline define:vars={{ transparentOnTop, transparentPaths }}>
  ;(() => {
    window.__mennisHeaderConfig = { transparentOnTop, transparentPaths }

    const getHeaderParts = () => {
      const header = document.querySelector("[data-header]")
      const btn = document.querySelector("[data-menu-button]")
      const overlay = document.querySelector("[data-menu-overlay]")
      const icon = btn ? btn.querySelector(".hamburger") : null

      return { header, btn, overlay, icon }
    }

    const setMenuOpen = open => {
      const { header, btn, overlay, icon } = getHeaderParts()
      if (!btn || !overlay || !header) return

      overlay.classList.toggle("is-open", open)
      overlay.setAttribute("aria-hidden", String(!open))
      btn.setAttribute("aria-expanded", String(open))
      if (icon) icon.classList.toggle("is-open", open)

      header.classList.toggle("is-menu-open", open)

      document.documentElement.classList.toggle("overflow-hidden", open)
      document.body.classList.toggle("overflow-hidden", open)
    }

    const topThreshold = 8
    const normalizePath = path => path.replace(/\/$/, "") || "/"
    const canBeTransparent = () => {
      const config = window.__mennisHeaderConfig || {}
      const paths = Array.isArray(config.transparentPaths) ? config.transparentPaths : []
      return paths.length > 0 ? paths.includes(normalizePath(window.location.pathname)) : Boolean(config.transparentOnTop)
    }

    const updateHeaderBg = () => {
      const { header, overlay } = getHeaderParts()
      if (!header || !overlay) return
      if (overlay.classList.contains("is-open")) return

      if (!canBeTransparent()) {
        header.classList.add("is-solid")
        return
      }

      const y = window.scrollY || 0
      header.classList.toggle("is-solid", y > topThreshold)
    }

    if (!window.__mennisHeaderBound) {
      window.__mennisHeaderBound = true

      document.addEventListener("click", event => {
        const target = event.target
        if (!(target instanceof Element)) return

        const button = target.closest("[data-menu-button]")
        if (button) {
          const { overlay } = getHeaderParts()
          if (!overlay) return
          setMenuOpen(!overlay.classList.contains("is-open"))
          return
        }

        if (target.closest("[data-menu-backdrop]") || target.closest("[data-menu-link]")) {
          setMenuOpen(false)
        }
      })

      window.addEventListener("keydown", event => {
        if (event.key === "Escape") setMenuOpen(false)
      })

      window.addEventListener("hashchange", () => setMenuOpen(false))
      window.addEventListener("scroll", updateHeaderBg, { passive: true })
      document.addEventListener("astro:page-load", updateHeaderBg)
      document.addEventListener("astro:after-swap", updateHeaderBg)
    }

    updateHeaderBg()
  })()
</script>
