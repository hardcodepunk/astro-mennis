---
import { getSiteSettings } from "../lib/sanity.queries"

const siteSettings = await getSiteSettings()
const legalDocument = siteSettings?.legalDocument
const legalUrl = legalDocument?.url?.trim()
const legalLabel = legalDocument?.label?.trim() || "Privacy / Legal"
const legalFilename = legalDocument?.filename?.trim()
const legalDownloadUrl = legalUrl
  ? `${legalUrl}${legalUrl.includes("?") ? "&" : "?"}dl=${encodeURIComponent(legalFilename || legalLabel)}`
  : undefined

---

<footer id="contact" class="footer">
  <div class="footer-inner">
    <div class="footer-main">
      <a class="footer-brand" href="/" aria-label="De Mennis home">
        <picture>
          <source srcset="/logo.webp" type="image/webp" />
          <img src="/logo.png" width="96" height="96" alt="De Mennis logo" loading="lazy" decoding="async" />
        </picture>
      </a>

      <div class="footer-contact">
        <p class="footer-label ds-kicker ds-kicker--xsmall">Shoot at</p>
        <a href="mailto:hello@demennis.be" class="footer-mail ds-progress-link ds-title ds-title--tiny">HELLO@DEMENNIS.BE</a>
      </div>
    </div>

    <div class="footer-meta">
      {
        legalDownloadUrl ? (
          <a
            class="footer-legal ds-progress-link ds-progress-link--spacious"
            href={legalDownloadUrl}
            target="_blank"
            rel="noopener noreferrer"
            download={legalFilename}
          >
            {legalLabel}
          </a>
        ) : (
          <span></span>
        )
      }

      <a
        class="footer-instagram-link ds-progress-link ds-progress-link--spacious"
        href="https://www.instagram.com/demennis_/"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="footer-instagram" aria-hidden="true"></span>
        <span class="footer-instagram-copy">Instagram</span>
      </a>
    </div>
  </div>

  <style>
    .footer {
      width: 100%;
      padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 5vw, 4rem);
      background: var(--color-brand-secondary);
      color: var(--color-brand-primary);
      min-height: clamp(16rem, 34vh, 20rem);
    }

    .footer-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      min-height: 100%;
      gap: 1rem;
      width: min(100%, 44rem);
      margin: 0 auto;
      text-align: center;
      justify-content: flex-start;
    }

    .footer-main,
    .footer-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: clamp(1rem, 3vw, 2rem);
    }

    .footer-brand {
      display: inline-flex;
      width: clamp(3rem, 6vw, 4.2rem);
      opacity: 0.78;
      transition: opacity 160ms ease;
    }

    .footer-brand:hover {
      opacity: 1;
    }

    .footer-brand img {
      display: block;
      width: 100%;
      height: auto;
    }

    .footer-contact {
      display: grid;
      gap: 0.35rem;
      text-align: left;
    }

    .footer-label {
      margin: 0 0 0.35rem;
      color: color-mix(in srgb, var(--color-brand-primary) 72%, transparent);
      font-weight: 400;
    }

    .footer-mail {
      color: var(--color-brand-primary);
    }

    .footer-meta {
      align-items: center;
      margin-top: auto;
      padding-top: clamp(1.25rem, 4vw, 2rem);
    }

    .footer-instagram-link {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      color: var(--color-brand-primary);
      font-size: 0.72rem;
      font-weight: 400;
      line-height: 1.2;
      text-decoration: none;
    }

    .footer-instagram {
      display: inline-block;
      width: 1em;
      height: 1em;
      background: currentColor;
      mask: url("/icons/instagram.png") center / contain no-repeat;
      -webkit-mask: url("/icons/instagram.png") center / contain no-repeat;
    }

    .footer-instagram-copy {
      display: inline-block;
    }

    .footer-legal {
      color: var(--color-brand-primary);
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0;
      line-height: 1.2;
      text-decoration: none;
    }

    @media (max-width: 700px) {
      .footer-main,
      .footer-meta {
        align-items: center;
        flex-direction: column;
      }

      .footer-contact {
        text-align: center;
      }
    }
  </style>
</footer>
