---
import { getSiteSettings } from "../lib/sanity.queries"

const siteSettings = await getSiteSettings()
const legalDocument = siteSettings?.legalDocument
const legalUrl = legalDocument?.url?.trim()
const legalLabel = legalDocument?.label?.trim() || "Privacy / Legal"
const legalFilename = legalDocument?.filename?.trim()
const legalDownloadUrl = legalUrl
  ? `${legalUrl}${legalUrl.includes("?") ? "&" : "?"}dl=${encodeURIComponent(legalFilename || legalLabel)}`
  : undefined

---

<footer id="contact" class="w-full py-20">
  <div class="flex flex-col items-center justify-center px-6 text-center gap-4">
    <picture>
      <source srcset="/logo.webp" type="image/webp" />
      <img src="/logo.png" width="96" height="96" alt="De Mennis logo" class="w-20 md:w-24 opacity-70" loading="lazy" decoding="async" />
    </picture>

    <a href="mailto:hello@demennis.be" class="font-display text-2xl tracking-widest text-brand-primary">
      HELLO@DEMENNIS.BE
    </a>

    <a
      class="footer-instagram-link"
      href="https://www.instagram.com/demennis_/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram"
    >
      <picture>
        <source srcset="/icons/instagram.webp" type="image/webp" />
        <img src="/icons/instagram.png" width="24" height="24" alt="" class="w-6 h-6 object-contain footer-instagram" loading="lazy" decoding="async" />
      </picture>
    </a>

    {
      legalDownloadUrl ? (
        <p class="footer-legal">
          <a href={legalDownloadUrl} target="_blank" rel="noopener noreferrer" download={legalFilename}>
            {legalLabel}
          </a>
        </p>
      ) : null
    }
  </div>

  <style>
    .footer-instagram {
      filter: brightness(0) saturate(100%) invert(96%) sepia(4%) saturate(1313%) hue-rotate(204deg) brightness(105%)
        contrast(99%);
      transition: filter 160ms ease;
    }

    .footer-instagram-link:hover .footer-instagram {
      filter: brightness(0) invert(1);
    }

    .footer-legal {
      margin: 0.85rem 0 0;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.12em;
      line-height: 1.2;
      text-transform: uppercase;
    }

    .footer-legal a {
      color: var(--color-brand-primary);
      text-decoration: none;
      opacity: 0.74;
      transition:
        opacity 160ms ease,
        color 160ms ease;
    }

    .footer-legal a:hover {
      color: #fff;
      opacity: 1;
    }
  </style>
</footer>
