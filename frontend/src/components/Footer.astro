---

<footer id="contact" class="w-full py-20">
  <div class="flex flex-col items-center justify-center px-6 text-center gap-4">
    <img src="/logo.png" width="96" height="96" alt="De Mennis logo" class="w-20 md:w-24 opacity-70" loading="lazy" decoding="async" />

    <a href="mailto:hello@demennis.be" class="font-display text-2xl tracking-widest text-brand-primary">
      HELLO@DEMENNIS.BE
    </a>

    <a
      class="footer-instagram-link"
      href="https://www.instagram.com/demennis_/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Instagram"
    >
      <img src="/icons/instagram.png" width="24" height="24" alt="" class="w-6 h-6 object-contain footer-instagram" loading="lazy" decoding="async" />
    </a>
  </div>

  <style>
    .footer-instagram {
      filter: brightness(0) saturate(100%) invert(76%) sepia(20%) saturate(814%) hue-rotate(211deg) brightness(93%)
        contrast(91%);
      transition: filter 160ms ease;
    }

    .footer-instagram-link:hover .footer-instagram {
      filter: brightness(0) invert(1);
    }
  </style>
</footer>
