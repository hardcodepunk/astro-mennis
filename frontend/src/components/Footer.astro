---
import { getSiteSettings } from "../lib/sanity.queries"

const siteSettings = await getSiteSettings()
const legalDocument = siteSettings?.legalDocument
const legalUrl = legalDocument?.url?.trim()
const legalLabel = legalDocument?.label?.trim() || "Privacy / Legal"
const legalFilename = legalDocument?.filename?.trim()
const legalDownloadUrl = legalUrl
  ? `${legalUrl}${legalUrl.includes("?") ? "&" : "?"}dl=${encodeURIComponent(legalFilename || legalLabel)}`
  : undefined

---

<footer id="contact" class="footer">
  <div class="footer-inner">
    <div class="footer-main">
      <a class="footer-brand" href="/" aria-label="De Mennis home">
        <picture>
          <source srcset="/logo.webp" type="image/webp" />
          <img src="/logo.png" width="96" height="96" alt="De Mennis logo" loading="lazy" decoding="async" />
        </picture>
      </a>

      <div class="footer-contact">
        <p class="footer-label">Shoot at</p>
        <a href="mailto:hello@demennis.be" class="footer-mail">HELLO@DEMENNIS.BE</a>
      </div>
    </div>

    <div class="footer-meta">
      {
        legalDownloadUrl ? (
          <a class="footer-legal" href={legalDownloadUrl} target="_blank" rel="noopener noreferrer" download={legalFilename}>
            {legalLabel}
          </a>
        ) : (
          <span></span>
        )
      }

      <a
        class="footer-instagram-link"
        href="https://www.instagram.com/demennis_/"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="footer-instagram" aria-hidden="true"></span>
        <span class="footer-instagram-copy">Instagram</span>
      </a>
    </div>
  </div>

  <style>
    .footer {
      width: 100%;
      padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 5vw, 4rem);
      background: var(--color-brand-secondary);
      color: var(--color-brand-primary);
    }

    .footer-inner {
      display: grid;
      justify-items: center;
      gap: 1rem;
      width: min(100%, 44rem);
      margin: 0 auto;
      text-align: center;
    }

    .footer-main,
    .footer-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: clamp(1rem, 3vw, 2rem);
    }

    .footer-brand {
      display: inline-flex;
      width: clamp(3rem, 6vw, 4.2rem);
      opacity: 0.78;
      transition: opacity 160ms ease;
    }

    .footer-brand:hover {
      opacity: 1;
    }

    .footer-brand img {
      display: block;
      width: 100%;
      height: auto;
    }

    .footer-contact {
      display: grid;
      gap: 0.35rem;
      text-align: left;
    }

    .footer-label {
      margin: 0;
      color: color-mix(in srgb, var(--color-brand-primary) 72%, transparent);
      font-size: 0.66rem;
      font-weight: 400;
      letter-spacing: 0.14em;
      line-height: 1;
      text-transform: uppercase;
    }

    .footer-mail {
      position: relative;
      display: inline-block;
      padding-bottom: 0.1em;
      color: var(--color-brand-primary);
      font-family: var(--font-display, "Bebas Neue", sans-serif);
      font-size: clamp(1.15rem, 2.1vw, 1.55rem);
      font-weight: 400;
      letter-spacing: 0.03em;
      line-height: 0.9;
      text-decoration: none;
    }

    .footer-mail::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 2px;
      background: var(--color-brand-accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 220ms ease;
    }

    .footer-mail:hover::after,
    .footer-mail:focus-visible::after {
      transform: scaleX(1);
    }

    .footer-meta {
      align-items: center;
      min-height: 1.25rem;
    }

    .footer-instagram-link {
      position: relative;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding-bottom: 0.25rem;
      color: var(--color-brand-primary);
      font-size: 0.72rem;
      font-weight: 400;
      line-height: 1.2;
      text-decoration: none;
    }

    .footer-instagram {
      display: inline-block;
      width: 1em;
      height: 1em;
      background: currentColor;
      mask: url("/icons/instagram.png") center / contain no-repeat;
      -webkit-mask: url("/icons/instagram.png") center / contain no-repeat;
    }

    .footer-instagram-copy {
      position: relative;
      display: inline-block;
    }

    .footer-instagram-copy::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: -0.25rem;
      height: 2px;
      background: var(--color-brand-accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 220ms ease;
    }

    .footer-instagram-link:hover .footer-instagram-copy::after,
    .footer-instagram-link:focus-visible .footer-instagram-copy::after {
      transform: scaleX(1);
    }

    .footer-legal {
      position: relative;
      display: inline-block;
      padding-bottom: 0.25rem;
      color: var(--color-brand-primary);
      font-size: 0.72rem;
      font-weight: 400;
      letter-spacing: 0;
      line-height: 1.2;
      text-decoration: none;
    }

    .footer-legal::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 2px;
      background: var(--color-brand-accent);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 220ms ease;
    }

    .footer-legal:hover::after,
    .footer-legal:focus-visible::after {
      transform: scaleX(1);
    }

    @media (max-width: 700px) {
      .footer-main,
      .footer-meta {
        align-items: center;
        flex-direction: column;
      }

      .footer-contact {
        text-align: center;
      }
    }
  </style>
</footer>
