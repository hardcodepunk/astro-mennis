---
import "plyr/dist/plyr.css"
import Plyr from "plyr"
import PlyrPreview from "./PlyrPreview.astro"

type WorkMedia = { mode: "preview" } | { mode: "single"; youtubeUrl?: string } | { mode: "slider"; reels?: string[] }

const { work } = Astro.props as {
  work: {
    title?: string
    preview: { poster: string; mp4?: string; webm?: string }
    media?: WorkMedia
  }
}

const media = work.media

const youtubeUrl = media && media.mode === "single" ? (media.youtubeUrl ?? null) : null

const reels = media && media.mode === "slider" ? (media.reels ?? []).filter(Boolean).slice(0, 4) : []

const hasYouTube = Boolean(youtubeUrl)
const hasSlider = reels.length > 0
const init = hasYouTube || hasSlider
---

<div data-work-hero>
  {
    hasYouTube ? (
      <div class="hero-16x9">
        <div class="plyr__video-embed" data-yt-embed data-youtube-url={youtubeUrl} />
      </div>
    ) : hasSlider ? (
      <section class="yt-gallery" aria-label="Reels">
        <div class="yt-rail" data-yt-rail>
          {reels.map(url => (
            <article class="yt-slide" data-yt-slide>
              <div class="yt-frame">
                <div class="plyr__video-embed" data-yt-embed data-youtube-url={url} />
              </div>
            </article>
          ))}
        </div>
      </section>
    ) : (
      <PlyrPreview mp4={work.preview.mp4} webm={work.preview.webm} poster={work.preview.poster} />
    )
  }
</div>
<script define:vars={{ init }}>
  ;(() => {
    if (!init) return

    const root = document.querySelector("[data-work-hero]")
    if (!(root instanceof HTMLElement)) return

    const embeds = Array.from(root.querySelectorAll("[data-yt-embed]"))

    import("plyr").then(({ default: Plyr }) => {
      const players = embeds.map(el => new Plyr(el))

      const rail = root.querySelector("[data-yt-rail]")
      if (!(rail instanceof HTMLElement)) return

      const slides = Array.from(root.querySelectorAll("[data-yt-slide]"))

      const io = new IntersectionObserver(
        entries => {
          for (const entry of entries) {
            const idx = slides.indexOf(entry.target)
            if (idx === -1) continue
            if (!entry.isIntersecting) players[idx]?.pause()
          }
        },
        { root: rail, threshold: 0.7 },
      )

      slides.forEach(s => io.observe(s))
    })
  })()
</script>

<style>
  .hero-16x9 {
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
  }

  .yt-rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 100%;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 10px;
  }

  .yt-slide {
    scroll-snap-align: start;
  }

  .yt-frame {
    width: 100%;
    max-width: 520px;
    margin: 0 auto;
    aspect-ratio: 9 / 16;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
  }

  .yt-frame :global(iframe),
  .yt-frame :global(.plyr),
  .yt-frame :global(.plyr__video-wrapper) {
    width: 100%;
    height: 100%;
  }

  @media (min-width: 900px) {
    .yt-rail {
      grid-auto-columns: minmax(320px, 420px);
      justify-content: center;
    }
  }
</style>
