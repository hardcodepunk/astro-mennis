---
interface WorkItem {
  slug: string
  title: string
  category: string
  categorySlug: string
  client: string
  tagline: string
  preview: {
    poster: string
    webm?: string
    mp4?: string
  }
}

const { items = [] } = Astro.props as { items: WorkItem[] }
---

{items.length ? (
  <section class="fw">
    <div class="fw-inner">
      <div class="fw-grid">
        {items.map((work) => (
          <a class="fw-card" href={`/works/${work.slug}`} aria-label={`Open ${work.title}`}>
            <div class="fw-media" data-hover-video>
              <img class="fw-img" src={work.preview.poster} alt={work.title} loading="lazy" />
              <video class="fw-vid" muted loop playsinline preload="none" aria-hidden="true">
                {work.preview.webm ? <source data-src={work.preview.webm} type="video/webm" /> : null}
                {work.preview.mp4 ? <source data-src={work.preview.mp4} type="video/mp4" /> : null}
              </video>
            </div>

            <div class="fw-overlay">
              <div class="fw-kicker">{work.category}</div>
              <h3 class="fw-name">{work.title}</h3>
              {work.client ? <div class="fw-client">{work.client}</div> : null}
            </div>
          </a>
        ))}
      </div>

      <div class="fw-actions">
        <a class="fw-cta" href="/projects-grid">View all projects</a>
      </div>
    </div>

    <script>
      ;(() => {
        const finePointer = window.matchMedia("(hover: hover) and (pointer: fine)")
        if (!finePointer.matches) return

        const items = document.querySelectorAll(".fw-card")
        items.forEach(item => {
          if (!(item instanceof HTMLElement)) return

          const block = item.querySelector("[data-hover-video]")
          if (!(block instanceof HTMLElement)) return

          const video = block.querySelector("video")
          if (!(video instanceof HTMLVideoElement)) return

          const sources = Array.from(video.querySelectorAll("source"))
          let hydrated = false
          let playing = false

          const hydrate = () => {
            if (hydrated) return
            hydrated = true
            sources.forEach(s => {
              const src = s.getAttribute("data-src")
              if (src) s.setAttribute("src", src)
            })
            video.load()
          }

          const start = async () => {
            if (playing) return
            hydrate()
            try {
              await video.play()
              playing = true
              block.classList.add("is-playing")
            } catch {
              playing = false
              block.classList.remove("is-playing")
            }
          }

          const stop = () => {
            playing = false
            video.pause()
            video.currentTime = 0
            block.classList.remove("is-playing")
          }

          item.addEventListener("pointerenter", start)
          item.addEventListener("pointerleave", stop)
          item.addEventListener("focusin", start)
          item.addEventListener("focusout", stop)
        })
      })()
    </script>

    <style>
      .fw {
        padding: 96px 0;
        background: #000;
        color: #fff;
      }

      .fw-inner {
        max-width: 90rem;
        margin: 0 auto;
        padding: 0 1rem;
      }

      .fw-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
      }

      .fw-card {
        position: relative;
        display: block;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        background: #111;
        border-radius: 20px;
      }

      .fw-card:nth-child(1) {
        grid-column: 1 / -1;
      }

      .fw-media {
        position: relative;
        overflow: hidden;
      }

      .fw-card:nth-child(1) .fw-media {
        aspect-ratio: 16 / 9;
      }

      .fw-card:nth-child(2) .fw-media,
      .fw-card:nth-child(3) .fw-media {
        aspect-ratio: 1 / 1;
      }

      .fw-img,
      .fw-vid {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .fw-vid {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 180ms ease;
        pointer-events: none;
      }

      .fw-media.is-playing .fw-vid {
        opacity: 1;
      }

      .fw-overlay {
        position: absolute;
        inset: auto 0 0 0;
        padding: 1.25rem;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.78), rgba(0, 0, 0, 0));
      }

      .fw-card:nth-child(1) .fw-overlay {
        padding: 2rem;
      }

      .fw-kicker {
        font-size: 0.85rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.72);
      }

      .fw-name {
        margin: 0.35rem 0 0;
        font-family: var(--font-bebas, "Bebas Neue", sans-serif);
        font-size: clamp(1.5rem, 2.6vw, 2.4rem);
        line-height: 0.95;
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }

      .fw-card:nth-child(1) .fw-name {
        font-size: clamp(2.5rem, 4vw, 4rem);
      }

      .fw-client {
        margin-top: 0.35rem;
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.8);
      }

      .fw-actions {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
      }

      .fw-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 52px;
        padding: 10px 22px;
        border: 0;
        border-radius: 18px;
        background: var(--color-brand-primary);
        color: #000;
        font-family: var(--font-bebas, "Bebas Neue", sans-serif);
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition:
          background 180ms ease,
          color 180ms ease,
          transform 180ms ease;
      }

      .fw-cta:hover {
        background: #fff;
      }

      @media (max-width: 900px) {
        .fw-grid {
          grid-template-columns: 1fr;
        }

        .fw-card:nth-child(1) {
          grid-column: auto;
        }

        .fw-card .fw-media {
          aspect-ratio: 4 / 5;
        }

        .fw-card:nth-child(1) .fw-overlay {
          padding: 1.25rem;
        }

        .fw-card:nth-child(1) .fw-name {
          font-size: clamp(1.5rem, 2.6vw, 2.4rem);
        }
      }
    </style>
  </section>
) : null}