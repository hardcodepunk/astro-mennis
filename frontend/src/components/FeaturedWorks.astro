---
import WorkThumbnailCard from "./WorkThumbnailCard.astro"
import type { WorkItem } from "../lib/sanity.queries"

const { items = [] } = Astro.props as { items: WorkItem[] }
---

{items.length ? (
  <section id="projects" class="fw">
    <div class="fw-inner">
      <h2 class="sr-only">Featured projects</h2>

      <div class="fw-grid">
        {
          items.map((work, index) => (
            <WorkThumbnailCard
              work={work}
              headingTag="h3"
              variant={index === 0 ? "featuredPrimary" : "featuredSecondary"}
            />
          ))
        }
      </div>

      <div class="fw-actions">
        <a class="fw-cta" href="/projects">View all projects</a>
      </div>
    </div>

    <style>
      .fw {
        padding: 96px 0;
      }

      .fw-inner {
        max-width: 90rem;
        margin: 0 auto;
        padding: 0 1rem;
      }

      .fw-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
      }

      .fw-actions {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
      }

      .fw-cta {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 0 0.25rem;
        color: var(--color-brand-secondary);
        font-family: var(--font-bebas, "Bebas Neue", sans-serif);
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
      }

      .fw-cta::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 2px;
        background: var(--color-brand-accent);
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 220ms ease;
      }

      .fw-cta:hover::after,
      .fw-cta:focus-visible::after {
        transform: scaleX(1);
      }

      @media (max-width: 900px) {
        .fw-grid {
          grid-template-columns: 1fr;
        }

      }
    </style>
  </section>
) : null}
