---
import ThumbnailVideoController from "./ThumbnailVideoController.astro"
import WorkThumbnailCard from "./WorkThumbnailCard.astro"
import type { WorkItem } from "../lib/sanity.queries"

const { items = [] } = Astro.props as { items: WorkItem[] }
---

{items.length ? (
  <section id="projects" class="fw">
    <div class="fw-inner">
      <h2 class="sr-only">Featured projects</h2>

      <div class="fw-grid">
        {
          items.map((work, index) => (
            <WorkThumbnailCard
              work={work}
              headingTag="h3"
              variant={index === 0 ? "featuredPrimary" : "featuredSecondary"}
            />
          ))
        }
      </div>

      <div class="fw-actions">
        <a class="fw-cta" href="/projects">View all projects</a>
      </div>
    </div>

    <ThumbnailVideoController />

    <style>
      .fw {
        padding: 96px 0;
      }

      .fw-inner {
        max-width: 90rem;
        margin: 0 auto;
        padding: 0 1rem;
      }

      .fw-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
      }

      .fw-actions {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
      }

      .fw-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 52px;
        padding: 10px 22px;
        border: 0;
        border-radius: 0;
        color: #fff;
        background: var(--color-brand-secondary);
        font-family: var(--font-bebas, "Bebas Neue", sans-serif);
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        cursor: pointer;
        transition:
          background 180ms ease,
          color 180ms ease,
          transform 180ms ease;
      }

      .fw-cta:hover {
        background: #fff;
        color: var(--color-brand-secondary);
      }

      @media (max-width: 900px) {
        .fw-grid {
          grid-template-columns: 1fr;
        }

      }
    </style>
  </section>
) : null}
