---
import WorkThumbnailCard from "./WorkThumbnailCard.astro"
import type { WorkItem } from "../lib/sanity.queries"

const { items = [] } = Astro.props as { items: WorkItem[] }
---

{items.length ? (
  <section id="projects" class="fw">
    <div class="fw-inner ds-shell">
      <h2 class="sr-only">Featured projects</h2>

      <div class="fw-grid">
        {
          items.map((work, index) => (
            <WorkThumbnailCard
              work={work}
              headingTag="h3"
              variant={index === 0 ? "featuredPrimary" : "featuredSecondary"}
            />
          ))
        }
      </div>

      <div class="fw-actions">
        <a class="fw-cta fw-link ds-progress-link" href="/projects">View all projects</a>
      </div>
    </div>

    <style>
      .fw {
        padding: 96px 0;
      }

      .fw-inner {
        margin: 0 auto;
      }

      .fw-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
      }

      .fw-actions {
        display: flex;
        justify-content: center;
        margin-top: 2rem;
      }

      .fw-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
      }

      .fw-link {
        color: var(--color-brand-secondary);
        font-family: var(--font-body);
        text-transform: none;
        font-size: 1rem;
        letter-spacing: 0.01em;
        padding: 0 0 0.25rem;
        text-decoration: none;
        cursor: pointer;
      }

      @media (max-width: 900px) {
        .fw-grid {
          grid-template-columns: 1fr;
        }

      }
    </style>
  </section>
) : null}
