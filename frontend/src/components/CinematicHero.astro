---
import { getVideoHeroSettings } from "../lib/sanity.queries"
import { cloudinaryImage, safePosterUrl } from "../lib/media"

const DEFAULT_MP4 =
  "https://res.cloudinary.com/hardcodepunk/video/upload/q_auto:eco,vc_h264,ac_aac,f_mp4/v1737957147/wsuszohtmu2pks673muc.mp4"
const DEFAULT_WEBM =
  "https://res.cloudinary.com/hardcodepunk/video/upload/q_auto:eco,vc_vp9,f_webm/v1761381373/b8f7chk3u9s6jaqh4bae.webm"
const DEFAULT_POSTER =
  "https://res.cloudinary.com/hardcodepunk/video/upload/q_auto:eco,so_0,f_jpg,w_1600/v1737957147/wsuszohtmu2pks673muc.jpg"

const props = Astro.props
const needsSettings = !props.mp4 || !props.webm || !props.poster
const settings = needsSettings ? await getVideoHeroSettings() : null

const {
  mp4 = settings?.mp4 ?? DEFAULT_MP4,
  webm = settings?.webm ?? DEFAULT_WEBM,
  poster = settings?.poster ?? DEFAULT_POSTER,
  minRevealMs = 600,
} = props
const safePoster = safePosterUrl(poster, DEFAULT_POSTER)
const optimizedPoster = cloudinaryImage(safePoster, 1920)
---

<section class="vh-hero" data-min-reveal={minRevealMs}>
  <img
    class="vh-poster"
    src={optimizedPoster}
    width="1920"
    height="1080"
    alt=""
    decoding="async"
    fetchpriority="high"
    aria-hidden="true"
  />

  <video
    class="vh-video"
    muted
    playsinline
    preload="none"
    poster={optimizedPoster}
    loop
    width="1920"
    height="1080"
    disableRemotePlayback
    aria-hidden="true"
    data-webm={webm}
    data-mp4={mp4}
  >
  </video>

  <div class="vh-overlay" aria-hidden="true"></div>

  <div class="vh-bottom-left">
    <a
      href="mailto:hello@demennis.be"
      class="font-display text-2xl tracking-widest text-white/90 hover:text-white transition-colors uppercase opacity-50 hover:opacity-100"
    >
      Shoot hello@demennis.be
    </a>
  </div>

  <script>
    async function initCinematicHero(root: Element) {
      if (!(root instanceof HTMLElement) || root.dataset.vhHeroInited === "1") return
      root.dataset.vhHeroInited = "1"

      const video = root.querySelector("video")
      if (!(video instanceof HTMLVideoElement)) return

      const controller = new AbortController()
      const { signal } = controller
      const mountedAt = Date.now()
      const minRevealMs = Number(root.getAttribute("data-min-reveal") || "600")

      let revealed = false

      const reveal = () => {
        if (revealed) return
        revealed = true
        root.classList.add("is-revealed")
        root.classList.add("is-playing")
      }

      const revealWithMin = () => {
        const elapsed = Date.now() - mountedAt
        const delay = Math.max(0, minRevealMs - elapsed)
        window.setTimeout(reveal, delay)
      }

      const motionAllowed = !window.matchMedia("(prefers-reduced-motion: reduce)").matches
      const desktopViewport = window.matchMedia("(min-width: 768px)").matches

      if (!motionAllowed || !desktopViewport) {
        root.dataset.reduced = "1"
        reveal()
        return
      }

      const attachVideoSources = () => {
        if (video.dataset.sourcesAttached === "1") return
        video.dataset.sourcesAttached = "1"

        const webm = video.dataset.webm
        const mp4 = video.dataset.mp4

        if (webm) {
          const source = document.createElement("source")
          source.src = webm
          source.type = "video/webm"
          video.append(source)
        }

        if (mp4) {
          const source = document.createElement("source")
          source.src = mp4
          source.type = "video/mp4"
          video.append(source)
        }

        video.load()
        video.play().catch(revealWithMin)
      }

      const onPlaying = () => revealWithMin()
      const onLoadedData = () => revealWithMin()

      video.addEventListener("playing", onPlaying, { signal })
      video.addEventListener("loadeddata", onLoadedData, { signal })

      window.setTimeout(revealWithMin, 1500)

      const loadVideo = () => {
        const requestIdle = window.requestIdleCallback

        if (typeof requestIdle === "function") {
          requestIdle(attachVideoSources, { timeout: 1200 })
        } else {
          globalThis.setTimeout(attachVideoSources, 350)
        }
      }

      if (document.readyState === "complete") {
        loadVideo()
      } else {
        window.addEventListener("load", loadVideo, { once: true, signal })
      }

      let cleanedUp = false
      const cleanup = () => {
        if (cleanedUp) return
        cleanedUp = true
        controller.abort()
      }

      document.addEventListener("astro:before-swap", cleanup, { once: true })
      window.addEventListener("beforeunload", cleanup, { once: true })
    }

    function bootCinematicHero() {
      document.querySelectorAll(".vh-hero").forEach(initCinematicHero)
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bootCinematicHero, { once: true })
    } else {
      bootCinematicHero()
    }

    document.addEventListener("astro:page-load", bootCinematicHero)
  </script>

  <style>
    .vh-poster {
      position: absolute;
      inset: 0;
      z-index: 0;
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 1;
      transition: opacity 0.8s ease-out;
    }

    .vh-hero.is-playing .vh-poster {
      opacity: 0;
    }

    .vh-bottom-left {
      position: absolute;
      left: 0;
      bottom: 3rem;
      padding: 0 1.5rem;
      z-index: 30;
    }

    @media (max-width: 640px) {
      .vh-bottom-left {
        left: 50%;
        right: auto;
        transform: translateX(-50%);
        bottom: 1.5rem;
        padding: 0;
        text-align: center;
        width: calc(100% - 2rem);
      }
    }
  </style>
</section>
