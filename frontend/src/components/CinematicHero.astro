---
import { getVideoHeroSettings } from "../lib/sanity.queries"
import { imageAttributes, safePosterUrl, defaultHeroMedia } from "../lib/media"

const DEFAULT_CAPTION = "wild concepts captured by edgy and atypical video production"

const props = Astro.props
const needsSettings = !props.mp4 || !props.webm || !props.poster
const settings = needsSettings ? await getVideoHeroSettings() : null

const {
  mp4 = settings?.mp4 ?? defaultHeroMedia.mp4,
  webm = settings?.webm ?? defaultHeroMedia.webm,
  poster = settings?.poster ?? defaultHeroMedia.poster,
  caption = settings?.caption,
  captionTextScale = settings?.captionTextScale ?? 100,
  captionUppercase = settings?.captionUppercase ?? true,
  minRevealMs = 600,
} = props
const safePoster = safePosterUrl(poster, defaultHeroMedia.poster)
const heroCaption = typeof caption === "string" && caption.trim() ? caption.trim() : DEFAULT_CAPTION
const captionScale = Math.min(1.8, Math.max(0.6, Number(captionTextScale) / 100 || 1))
const posterAttrs = imageAttributes({
  src: safePoster,
  widths: [480, 768, 1024, 1280, 1600, 1920],
  fallbackWidth: 1280,
  sizes: "100vw",
  quality: "auto:eco",
})
---

<section class="vh-hero" data-min-reveal={minRevealMs}>
  <img
    class="vh-poster"
    src={posterAttrs.src}
    srcset={posterAttrs.srcset}
    sizes={posterAttrs.sizes}
    width="1920"
    height="1080"
    alt=""
    decoding="async"
    fetchpriority="high"
    aria-hidden="true"
  />

  <video
    class="vh-video"
    autoplay
    muted
    playsinline
    webkit-playsinline
    preload="none"
    poster={posterAttrs.src}
    loop
    width="1920"
    height="1080"
    disableRemotePlayback
    aria-hidden="true"
    data-webm={webm}
    data-mp4={mp4}
  >
  </video>

  <div class="vh-overlay" aria-hidden="true"></div>

  <div class="vh-bottom-left" style={`--vh-caption-scale: ${captionScale};`}>
    {heroCaption ? <p class:list={["vh-caption", captionUppercase && "is-uppercase"]}>{heroCaption}</p> : null}
  </div>

  <script>
    async function initCinematicHero(root: Element) {
      if (!(root instanceof HTMLElement) || root.dataset.vhHeroInited === "1") return
      root.dataset.vhHeroInited = "1"

      const video = root.querySelector("video")
      if (!(video instanceof HTMLVideoElement)) return

      const controller = new AbortController()
      const { signal } = controller
      const mountedAt = Date.now()
      const minRevealMs = Number(root.getAttribute("data-min-reveal") || "600")

      let revealed = false

      const reveal = () => {
        if (revealed) return
        revealed = true
        root.classList.add("is-revealed")
        root.classList.add("is-playing")
      }

      const revealWithMin = () => {
        const elapsed = Date.now() - mountedAt
        const delay = Math.max(0, minRevealMs - elapsed)
        window.setTimeout(reveal, delay)
      }

      const prepareVideo = () => {
        video.muted = true
        video.defaultMuted = true
        video.playsInline = true
        video.setAttribute("muted", "")
        video.setAttribute("playsinline", "")
        video.setAttribute("webkit-playsinline", "")
      }

      const motionAllowed = !window.matchMedia("(prefers-reduced-motion: reduce)").matches

      if (!motionAllowed) {
        root.dataset.reduced = "1"
        return
      }

      const attachVideoSources = () => {
        if (video.dataset.sourcesAttached === "1") return
        video.dataset.sourcesAttached = "1"

        const webm = video.dataset.webm
        const mp4 = video.dataset.mp4

        if (mp4) {
          const source = document.createElement("source")
          source.src = mp4
          source.type = "video/mp4"
          video.append(source)
        }

        if (webm) {
          const source = document.createElement("source")
          source.src = webm
          source.type = "video/webm"
          video.append(source)
        }

        video.load()
      }

      let playing = false
      let pendingStart = false

      const scheduleStart = () => {
        if (pendingStart || playing) return
        pendingStart = true

        const retry = () => {
          pendingStart = false
          startVideo()
        }

        video.addEventListener("loadeddata", retry, { once: true, signal })
        video.addEventListener("canplay", retry, { once: true, signal })
        window.setTimeout(retry, 180)
      }

      const startVideo = async () => {
        if (playing) return
        pendingStart = false
        attachVideoSources()
        prepareVideo()

        try {
          await video.play()
          playing = true
          revealWithMin()
        } catch {
          playing = false
          if (video.readyState < HTMLMediaElement.HAVE_CURRENT_DATA) scheduleStart()
        }
      }

      const onPlaying = () => {
        playing = true
        revealWithMin()
      }

      video.addEventListener("playing", onPlaying, { signal })

      startVideo()
      window.addEventListener("pageshow", startVideo, { signal })
      document.addEventListener(
        "visibilitychange",
        () => {
          if (!document.hidden) startVideo()
        },
        { signal },
      )

      window.setTimeout(startVideo, 450)

      let cleanedUp = false
      const cleanup = () => {
        if (cleanedUp) return
        cleanedUp = true
        controller.abort()
      }

      document.addEventListener("astro:before-swap", cleanup, { once: true })
      window.addEventListener("beforeunload", cleanup, { once: true })
    }

    function bootCinematicHero() {
      document.querySelectorAll(".vh-hero").forEach(initCinematicHero)
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", bootCinematicHero, { once: true })
    } else {
      bootCinematicHero()
    }

    document.addEventListener("astro:page-load", bootCinematicHero)
    document.addEventListener("astro:after-swap", bootCinematicHero)
  </script>

  <style>
    .vh-poster {
      position: absolute;
      inset: 0;
      z-index: 0;
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 1;
      transition: opacity 0.8s ease-out;
    }

    .vh-hero.is-playing .vh-poster {
      opacity: 0;
    }

    .vh-bottom-left {
      position: absolute;
      left: 0;
      bottom: 3rem;
      padding: 0 1.5rem;
      z-index: 30;
      color: #fff;
    }

    .vh-caption {
      margin: 0;
      font-family: var(--font-bebas, "Bebas Neue", sans-serif);
      font-weight: 400;
      letter-spacing: 0.08em;
    }

    .vh-caption {
      max-width: min(28rem, calc(100vw - 3rem));
      font-size: clamp(
        calc(2rem * var(--vh-caption-scale)),
        calc(4.2vw * var(--vh-caption-scale)),
        calc(4.2rem * var(--vh-caption-scale))
      );
      line-height: 0.95;
      color: #fff;
    }

    .is-uppercase {
      text-transform: uppercase;
    }

    @media (max-width: 640px) {
      .vh-bottom-left {
        left: 0;
        bottom: 1.5rem;
        padding: 0 1.5rem;
        text-align: left;
        width: calc(100% - 2rem);
      }
    }
  </style>
</section>
