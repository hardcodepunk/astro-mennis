---
import "plyr/dist/plyr.css"
import VideoPreview from "./VideoPreview.astro"
import { youtubeId as parseYouTubeId, youtubePoster } from "../lib/media"

type WorkMedia = { mode: "preview" } | { mode: "single"; youtubeUrl?: string } | { mode: "slider"; reels?: string[] }

const { work } = Astro.props as {
  work: {
    title?: string
    preview: { poster: string; mp4?: string; webm?: string }
    media?: WorkMedia
  }
}

function getYouTubeId(input?: string | null): string | null {
  return parseYouTubeId(input) ?? null
}

const media = work.media
const youtubeId = media && media.mode === "single" ? getYouTubeId(media.youtubeUrl ?? null) : null
const reelIds =
  media && media.mode === "slider"
    ? (media.reels ?? [])
        .map(u => getYouTubeId(u))
        .filter((x): x is string => Boolean(x))
        .slice(0, 8)
    : []

const hasYouTube = Boolean(youtubeId)
const hasSlider = reelIds.length > 0
const hasSliderNav = reelIds.length > 1

function ytPoster(id: string) {
  return youtubePoster(id, "maxres")!
}

function ytPosterFallback(id: string) {
  return youtubePoster(id, "hq")!
}
---

<div data-work-hero>
  {
    hasYouTube ? (
      <div class="hero-16x9">
        <div class="yt-frame yt-frame--16x9" data-yt-frame>
          <div
            class="plyr__video-embed yt-embed"
            data-yt-embed
            data-yt-ratio="16:9"
            data-plyr-provider="youtube"
            data-plyr-embed-id={youtubeId}
          />
          <button class="yt-overlay" type="button" aria-label="Play video" data-yt-overlay>
            <img
              class="yt-overlay__img"
              alt=""
              loading="eager"
              decoding="async"
              fetchpriority="high"
              width="1280"
              height="720"
              src={ytPoster(youtubeId!)}
              onerror={`this.onerror=null;this.src='${ytPosterFallback(youtubeId!)}'`}
            />
            <span class="yt-overlay__play" aria-hidden="true" />
          </button>
        </div>
      </div>
    ) : hasSlider ? (
      <section class="yt-gallery" aria-label="Reels">
        {hasSliderNav ? (
          <button class="yt-nav yt-nav--prev" type="button" aria-label="Previous" data-yt-prev>
            <span class="yt-nav__chevron" aria-hidden="true"></span>
          </button>
        ) : null}

        <div class="yt-rail" data-yt-rail>
          {reelIds.map((id, index) => (
            <article class="yt-slide" data-yt-slide>
              <div class="yt-frame yt-frame--9x16" data-yt-frame>
                <div
                  class="plyr__video-embed yt-embed"
                  data-yt-embed
                  data-yt-ratio="9:16"
                  data-plyr-provider="youtube"
                  data-plyr-embed-id={id}
                />
                <button class="yt-overlay" type="button" aria-label="Play reel" data-yt-overlay>
                  <img
                    class="yt-overlay__img"
                    alt=""
                    loading={index === 0 ? "eager" : "lazy"}
                    decoding="async"
                    fetchpriority={index === 0 ? "high" : undefined}
                    width="720"
                    height="1280"
                    src={ytPoster(id)}
                    onerror={`this.onerror=null;this.src='${ytPosterFallback(id)}'`}
                  />
                  <span class="yt-overlay__play" aria-hidden="true" />
                </button>
              </div>
            </article>
          ))}
        </div>

        {hasSliderNav ? (
          <button class="yt-nav yt-nav--next" type="button" aria-label="Next" data-yt-next>
            <span class="yt-nav__chevron" aria-hidden="true"></span>
          </button>
        ) : null}
      </section>
    ) : (
      <VideoPreview mp4={work.preview.mp4} webm={work.preview.webm} poster={work.preview.poster} />
    )
  }
</div>

<style>
  .hero-16x9 {
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
  }

  .yt-gallery {
    position: relative;
  }

  .yt-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 56px;
    height: 56px;
    border-radius: 0;
    border: 2px solid rgba(255, 255, 255, 0.92);
    background: var(--color-brand-secondary);
    display: grid;
    place-items: center;
    cursor: pointer;
    z-index: 30;
  }

  .yt-nav__chevron {
    width: 13px;
    height: 13px;
    border-top: 4px solid #fff;
    border-right: 4px solid #fff;
  }

  .yt-nav--prev .yt-nav__chevron {
    transform: translateX(3px) rotate(-135deg);
  }

  .yt-nav--next .yt-nav__chevron {
    transform: translateX(-3px) rotate(45deg);
  }

  .yt-nav--prev {
    left: -12px;
  }

  .yt-nav--next {
    right: -12px;
  }

  .yt-rail {
    display: flex;
    gap: 18px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x;
    overscroll-behavior-x: contain;
    padding: 10px 0 16px;
  }

  .yt-slide {
    flex: 0 0 auto;
    display: flex;
    justify-content: center;
  }

  .yt-frame {
    position: relative;
    overflow: hidden;
    border-radius: 0;
    background: var(--color-brand-secondary);
  }

  .yt-frame--16x9 {
    width: 100%;
    aspect-ratio: 16 / 9;
  }

  .yt-frame--9x16 {
    width: min(420px, 86vw);
    aspect-ratio: 9 / 16;
  }

  .yt-embed {
    position: absolute;
    inset: 0;
  }

  .yt-frame :global(.plyr),
  .yt-frame :global(.plyr__video-wrapper),
  .yt-frame :global(.plyr__video-embed),
  .yt-frame :global(iframe) {
    width: 100%;
    height: 100%;
  }

  .yt-frame :global(.plyr__poster) {
    display: none;
  }

  .yt-overlay {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: pointer;
    z-index: 5;
  }

  .yt-overlay__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .yt-overlay__play {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 76px;
    height: 76px;
    transform: translate(-50%, -50%);
    border-radius: 0;
    background: rgba(255, 255, 255, 0.18);
  }

  .yt-overlay__play::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-42%, -50%);
    border-left: 18px solid rgba(255, 255, 255, 0.9);
    border-top: 12px solid transparent;
    border-bottom: 12px solid transparent;
  }

  .yt-frame.is-playing .yt-overlay {
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease;
  }

  @media (min-width: 900px) {
    .yt-frame--9x16 {
      width: 380px;
    }
  }
</style>

{hasYouTube || hasSlider ? <script src="../scripts/workMediaDisplayScript.ts"></script> : null}
