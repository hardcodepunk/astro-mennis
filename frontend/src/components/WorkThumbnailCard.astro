---
import type { WorkItem } from "../lib/sanity.queries"

type HeadingTag = "h2" | "h3"
type CardVariant = "default" | "featuredPrimary" | "featuredSecondary"

const {
  work,
  headingTag = "h2",
  variant = "default",
} = Astro.props as {
  work: WorkItem
  headingTag?: HeadingTag
  variant?: CardVariant
}

const Heading = headingTag
const shouldAutoplay = Boolean(work.thumbnailAutoplay && (work.preview.webm || work.preview.mp4))
---

<a
  class:list={[
    "work-card",
    variant === "featuredPrimary" && "work-card--featured work-card--featured-primary",
    variant === "featuredSecondary" && "work-card--featured work-card--featured-secondary",
  ]}
  href={`/works/${work.slug}`}
  aria-label={`Open ${work.title}`}
  data-thumbnail-card
>
  <div class:list={["work-card-media", shouldAutoplay && "is-playing"]} data-thumbnail-video data-autoplay={shouldAutoplay ? "true" : "false"}>
    <img class="work-card-img" src={work.preview.poster} alt={work.title} loading="lazy" />
    <video class="work-card-vid" muted loop playsinline preload={shouldAutoplay ? "metadata" : "none"} autoplay={shouldAutoplay} aria-hidden="true">
      {work.preview.webm ? <source src={shouldAutoplay ? work.preview.webm : undefined} data-src={work.preview.webm} type="video/webm" /> : null}
      {work.preview.mp4 ? <source src={shouldAutoplay ? work.preview.mp4 : undefined} data-src={work.preview.mp4} type="video/mp4" /> : null}
    </video>
  </div>

  <div class="work-card-overlay">
    <div class="work-card-kicker">{work.category}</div>
    <Heading class="work-card-title">{work.title}</Heading>
  </div>
</a>

<style>
  .work-card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 0;
    text-decoration: none;
    color: inherit;
    background: #111;
  }

  .work-card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .work-card-img,
  .work-card-vid {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work-card-vid {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 180ms ease;
    pointer-events: none;
  }

  .work-card-media.is-playing .work-card-vid {
    opacity: 1;
  }

  .work-card-overlay {
    position: absolute;
    inset: auto 0 0 0;
    padding: 1.25rem;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.78), rgba(0, 0, 0, 0));
    color: #fff;
  }

  .work-card-kicker {
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
  }

  .work-card-title {
    margin: 0.35rem 0 0;
    font-family: var(--font-bebas, "Bebas Neue", sans-serif);
    font-size: clamp(1.6rem, 2.4vw, 2.5rem);
    line-height: 0.95;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .work-card--featured-primary {
    grid-column: 1 / -1;
  }

  .work-card--featured-primary .work-card-media {
    aspect-ratio: 16 / 9;
  }

  .work-card--featured-secondary .work-card-media {
    aspect-ratio: 1 / 1;
  }

  .work-card--featured-primary .work-card-overlay {
    padding: 2rem;
  }

  .work-card--featured .work-card-title {
    font-size: clamp(1.5rem, 2.6vw, 2.4rem);
  }

  .work-card--featured-primary .work-card-title {
    font-size: clamp(2.5rem, 4vw, 4rem);
  }

  @media (max-width: 900px) {
    .work-card--featured-primary {
      grid-column: auto;
    }

    .work-card--featured .work-card-media {
      aspect-ratio: 4 / 5;
    }

    .work-card--featured-primary .work-card-overlay {
      padding: 1.25rem;
    }

    .work-card--featured-primary .work-card-title {
      font-size: clamp(1.5rem, 2.6vw, 2.4rem);
    }
  }
</style>
