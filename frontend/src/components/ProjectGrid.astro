---
import ThumbnailVideoController from "./ThumbnailVideoController.astro"
import WorkThumbnailCard from "./WorkThumbnailCard.astro"
import type { WorkItem } from "../lib/sanity.queries"

interface CategoryItem {
  slug: string
  title: string
}

const {
  items = [],
  categories = [],
  activeSlug = "all",
} = Astro.props as {
  items: WorkItem[]
  categories: CategoryItem[]
  activeSlug?: string
}

const filterHref = (slug: string) => (slug === "all" ? "/projects" : `/projects/${slug}`)
---

<section class="pg">
  <div class="pg-inner">
    <div class="pg-filters">
      {
        activeSlug === "all" ? (
          <span class="pg-pill is-active" aria-current="page">All</span>
        ) : (
          <a class="pg-pill" href={filterHref("all")}>All</a>
        )
      }

      {
        categories.map(cat =>
          activeSlug === cat.slug ? (
            <span class="pg-pill is-active" aria-current="page">{cat.title}</span>
          ) : (
            <a class="pg-pill" href={filterHref(cat.slug)}>{cat.title}</a>
          ),
        )
      }
    </div>

    <div class="pg-grid">
      {items.map(work => <WorkThumbnailCard work={work} headingTag="h2" />)}
    </div>
  </div>

  <ThumbnailVideoController />

  <style>
    .pg {
      padding: 96px 0 96px;
    }

    .pg-inner {
      max-width: 96rem;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .pg-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      justify-content: center;
      margin-bottom: 3rem;
    }

    .pg-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0.65rem 1.25rem;
      border: 1px solid var(--color-brand-secondary);
      border-radius: 999px;
      color: var(--color-brand-secondary);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-size: 0.95rem;
      transition:
        background 160ms ease,
        color 160ms ease;
    }

    .pg-pill.is-active {
      background: var(--color-brand-secondary);
      color: var(--color-brand-primary);
      cursor: default;
    }

    .pg-pill:not(.is-active):hover {
      background: var(--color-brand-secondary);
      border-color: var(--color-brand-secondary);
      color: var(--color-brand-primary);
    }

    .pg-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.25rem;
    }

    @media (max-width: 1000px) {
      .pg-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 700px) {
      .pg-grid {
        grid-template-columns: 1fr;
      }

      .pg {
        padding-top: 88px;
      }

      .pg-filters {
        gap: 0.5rem;
        margin-bottom: 2rem;
      }

      .pg-pill {
        min-height: 40px;
        padding: 0.5rem 0.9rem;
        font-size: 0.82rem;
      }
    }
  </style>
</section>
